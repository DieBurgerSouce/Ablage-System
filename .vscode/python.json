  "FastAPI Router": {
    "prefix": "router",
    "body": [
      "\"\"\"${1:Module} API Router",
      "",
      "${2:Description of this API module}",
      "\"\"\"",
      "from typing import List, Optional",
      "from fastapi import APIRouter, Depends, HTTPException, status",
      "from sqlalchemy.ext.asyncio import AsyncSession",
      "import structlog",
      "",
      "from app.api.dependencies import get_db, get_current_user",
      "from app.db.schemas import ${3:SchemaName}, ${3:SchemaName}Create, ${3:SchemaName}Update",
      "from app.services import ${4:service_name}",
      "from app.db.models import User",
      "",
      "logger = structlog.get_logger(__name__)",
      "router = APIRouter(prefix=\"/${5:endpoint}\", tags=[\"${6:tag}\"])",
      "",
      "",
      "@router.get(\"/\", response_model=List[${3:SchemaName}])",
      "async def list_${5:endpoint}(",
      "    db: AsyncSession = Depends(get_db),",
      "    current_user: User = Depends(get_current_user),",
      "    skip: int = 0,",
      "    limit: int = 100",
      ") -> List[${3:SchemaName}]:",
      "    \"\"\"Liste alle ${6:tag}.\"\"\"",
      "    logger.info(",
      "        \"list_${5:endpoint}\",",
      "        user_id=current_user.id,",
      "        skip=skip,",
      "        limit=limit",
      "    )",
      "    return await ${4:service_name}.get_all(db, skip=skip, limit=limit)",
      "",
      "",
      "@router.get(\"/{id}\", response_model=${3:SchemaName})",
      "async def get_${7:singular}(",
      "    id: str,",
      "    db: AsyncSession = Depends(get_db),",
      "    current_user: User = Depends(get_current_user)",
      ") -> ${3:SchemaName}:",
      "    \"\"\"Hole einzelnes ${7:singular}.\"\"\"",
      "    obj = await ${4:service_name}.get(db, id)",
      "    if not obj:",
      "        raise HTTPException(",
      "            status_code=status.HTTP_404_NOT_FOUND,",
      "            detail=\"${7:singular} nicht gefunden\"",
      "        )",
      "    return obj",
      "",
      "",
      "@router.post(\"/\", response_model=${3:SchemaName}, status_code=status.HTTP_201_CREATED)",
      "async def create_${7:singular}(",
      "    data: ${3:SchemaName}Create,",
      "    db: AsyncSession = Depends(get_db),",
      "    current_user: User = Depends(get_current_user)",
      ") -> ${3:SchemaName}:",
      "    \"\"\"Erstelle neues ${7:singular}.\"\"\"",
      "    logger.info(\"create_${7:singular}\", user_id=current_user.id)",
      "    return await ${4:service_name}.create(db, data, owner_id=current_user.id)",
      "$0"
    ],
    "description": "Create a FastAPI router with CRUD endpoints"
  },
