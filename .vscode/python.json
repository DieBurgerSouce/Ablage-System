  "Database Repository": {
    "prefix": "repo",
    "body": [
      "from typing import List, Optional",
      "from sqlalchemy import select",
      "from sqlalchemy.ext.asyncio import AsyncSession",
      "from app.db.models import ${1:ModelName}",
      "from app.db.schemas import ${1:ModelName}Create, ${1:ModelName}Update",
      "",
      "",
      "class ${1:ModelName}Repository:",
      "    \"\"\"Repository for ${1:ModelName} database operations.\"\"\"",
      "    ",
      "    @staticmethod",
      "    async def get(",
      "        db: AsyncSession,",
      "        id: str",
      "    ) -> Optional[${1:ModelName}]:",
      "        \"\"\"Get ${1:ModelName} by ID.\"\"\"",
      "        result = await db.execute(",
      "            select(${1:ModelName}).where(${1:ModelName}.id == id)",
      "        )",
      "        return result.scalar_one_or_none()",
      "    ",
      "    @staticmethod",
      "    async def get_all(",
      "        db: AsyncSession,",
      "        skip: int = 0,",
      "        limit: int = 100",
      "    ) -> List[${1:ModelName}]:",
      "        \"\"\"Get all ${1:ModelName} with pagination.\"\"\"",
      "        result = await db.execute(",
      "            select(${1:ModelName}).offset(skip).limit(limit)",
      "        )",
      "        return result.scalars().all()",
      "    ",
      "    @staticmethod",
      "    async def create(",
      "        db: AsyncSession,",
      "        obj_in: ${1:ModelName}Create",
      "    ) -> ${1:ModelName}:",
      "        \"\"\"Create new ${1:ModelName}.\"\"\"",
      "        db_obj = ${1:ModelName}(**obj_in.dict())",
      "        db.add(db_obj)",
      "        await db.commit()",
      "        await db.refresh(db_obj)",
      "        return db_obj",
      "    ",
      "    @staticmethod",
      "    async def update(",
      "        db: AsyncSession,",
      "        id: str,",
      "        obj_in: ${1:ModelName}Update",
      "    ) -> Optional[${1:ModelName}]:",
      "        \"\"\"Update ${1:ModelName}.\"\"\"",
      "        db_obj = await ${1:ModelName}Repository.get(db, id)",
      "        if not db_obj:",
      "            return None",
      "        ",
      "        update_data = obj_in.dict(exclude_unset=True)",
      "        for field, value in update_data.items():",
      "            setattr(db_obj, field, value)",
      "        ",
      "        await db.commit()",
      "        await db.refresh(db_obj)",
      "        return db_obj",
      "    ",
      "    @staticmethod",
      "    async def delete(",
      "        db: AsyncSession,",
      "        id: str",
      "    ) -> bool:",
      "        \"\"\"Delete ${1:ModelName}.\"\"\"",
      "        db_obj = await ${1:ModelName}Repository.get(db, id)",
      "        if not db_obj:",
      "            return False",
      "        ",
      "        await db.delete(db_obj)",
      "        await db.commit()",
      "        return True",
      "$0"
    ],
    "description": "Create database repository with CRUD operations"
  }
