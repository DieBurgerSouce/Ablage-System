  "FastAPI Router with CRUD": {
    "prefix": "router-crud",
    "description": "Create a FastAPI router with CRUD operations",
    "body": [
      "\"\"\"${1:ResourceName} API endpoints.\"\"\"",
      "",
      "from typing import List",
      "from fastapi import APIRouter, Depends, HTTPException, status",
      "from sqlalchemy.ext.asyncio import AsyncSession",
      "import structlog",
      "",
      "from app.api.dependencies import get_db, get_current_user",
      "from app.db.models import ${2:ModelName}, User",
      "from app.db.schemas import ${2:ModelName}Create, ${2:ModelName}Response, ${2:ModelName}Update",
      "from app.services.${3:service_name} import ${4:ServiceClass}",
      "",
      "logger = structlog.get_logger(__name__)",
      "router = APIRouter(prefix=\"/${5:resource}\", tags=[\"${5:resource}\"])",
      "",
      "",
      "@router.post(\"/\", response_model=${2:ModelName}Response, status_code=status.HTTP_201_CREATED)",
      "async def create_${6:resource}(",
      "    data: ${2:ModelName}Create,",
      "    db: AsyncSession = Depends(get_db),",
      "    current_user: User = Depends(get_current_user),",
      ") -> ${2:ModelName}Response:",
      "    \"\"\"Create a new ${6:resource}.",
      "",
      "    Args:",
      "        data: ${6:resource} creation data",
      "        db: Database session",
      "        current_user: Authenticated user",
      "",
      "    Returns:",
      "        Created ${6:resource}",
      "    \"\"\"",
      "    logger.info(\"creating_${6:resource}\", user_id=current_user.id)",
      "",
      "    service = ${4:ServiceClass}(db)",
      "    ${6:resource} = await service.create(data, user_id=current_user.id)",
      "",
      "    logger.info(\"${6:resource}_created\", ${6:resource}_id=${6:resource}.id)",
      "    return ${6:resource}",
      "",
      "",
      "@router.get(\"/{${6:resource}_id}\", response_model=${2:ModelName}Response)",
      "async def get_${6:resource}(",
      "    ${6:resource}_id: str,",
      "    db: AsyncSession = Depends(get_db),",
      "    current_user: User = Depends(get_current_user),",
      ") -> ${2:ModelName}Response:",
      "    \"\"\"Get a ${6:resource} by ID.",
      "",
      "    Args:",
      "        ${6:resource}_id: ${6:resource} unique identifier",
      "        db: Database session",
      "        current_user: Authenticated user",
      "",
      "    Returns:",
      "        ${6:resource} data",
      "",
      "    Raises:",
      "        HTTPException: 404 if ${6:resource} not found or 403 if access denied",
      "    \"\"\"",
      "    service = ${4:ServiceClass}(db)",
      "    ${6:resource} = await service.get(${6:resource}_id)",
      "",
      "    if not ${6:resource}:",
      "        raise HTTPException(status_code=404, detail=\"${6:resource} nicht gefunden\")",
      "",
      "    # Check access permissions",
      "    if ${6:resource}.owner_id != current_user.id:",
      "        raise HTTPException(status_code=403, detail=\"Zugriff verweigert\")",
      "",
      "    return ${6:resource}",
      "",
      "",
      "@router.get(\"/\", response_model=List[${2:ModelName}Response])",
      "async def list_${5:resource}(",
      "    skip: int = 0,",
      "    limit: int = 100,",
      "    db: AsyncSession = Depends(get_db),",
      "    current_user: User = Depends(get_current_user),",
      ") -> List[${2:ModelName}Response]:",
      "    \"\"\"List ${5:resource} for the current user.",
      "",
      "    Args:",
      "        skip: Number of records to skip",
      "        limit: Maximum number of records to return",
      "        db: Database session",
      "        current_user: Authenticated user",
      "",
      "    Returns:",
      "        List of ${5:resource}",
      "    \"\"\"",
      "    service = ${4:ServiceClass}(db)",
      "    ${5:resource} = await service.list_by_user(",
      "        user_id=current_user.id, skip=skip, limit=limit",
      "    )",
      "    return ${5:resource}",
      "",
      "",
      "@router.patch(\"/{${6:resource}_id}\", response_model=${2:ModelName}Response)",
      "async def update_${6:resource}(",
      "    ${6:resource}_id: str,",
      "    data: ${2:ModelName}Update,",
      "    db: AsyncSession = Depends(get_db),",
      "    current_user: User = Depends(get_current_user),",
      ") -> ${2:ModelName}Response:",
      "    \"\"\"Update a ${6:resource}.",
      "",
      "    Args:",
      "        ${6:resource}_id: ${6:resource} unique identifier",
      "        data: Update data",
      "        db: Database session",
      "        current_user: Authenticated user",
      "",
      "    Returns:",
      "        Updated ${6:resource}",
      "    \"\"\"",
      "    service = ${4:ServiceClass}(db)",
      "    ${6:resource} = await service.get(${6:resource}_id)",
      "",
      "    if not ${6:resource}:",
      "        raise HTTPException(status_code=404, detail=\"${6:resource} nicht gefunden\")",
      "",
      "    if ${6:resource}.owner_id != current_user.id:",
      "        raise HTTPException(status_code=403, detail=\"Zugriff verweigert\")",
      "",
      "    updated = await service.update(${6:resource}_id, data)",
      "    logger.info(\"${6:resource}_updated\", ${6:resource}_id=${6:resource}_id)",
      "",
      "    return updated",
      "",
      "",
      "@router.delete(\"/{${6:resource}_id}\", status_code=status.HTTP_204_NO_CONTENT)",
      "async def delete_${6:resource}(",
      "    ${6:resource}_id: str,",
      "    db: AsyncSession = Depends(get_db),",
      "    current_user: User = Depends(get_current_user),",
      ") -> None:",
      "    \"\"\"Delete a ${6:resource}.",
      "",
      "    Args:",
      "        ${6:resource}_id: ${6:resource} unique identifier",
      "        db: Database session",
      "        current_user: Authenticated user",
      "    \"\"\"",
      "    service = ${4:ServiceClass}(db)",
      "    ${6:resource} = await service.get(${6:resource}_id)",
      "",
      "    if not ${6:resource}:",
      "        raise HTTPException(status_code=404, detail=\"${6:resource} nicht gefunden\")",
      "",
      "    if ${6:resource}.owner_id != current_user.id:",
      "        raise HTTPException(status_code=403, detail=\"Zugriff verweigert\")",
      "",
      "    await service.delete(${6:resource}_id)",
      "    logger.info(\"${6:resource}_deleted\", ${6:resource}_id=${6:resource}_id)",
      "$0"
    ]
  },

