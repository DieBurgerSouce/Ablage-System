  "Celery Task with Retry": {
    "prefix": "task-celery",
    "description": "Create a Celery task with retry and error handling",
    "body": [
      "@celery_app.task(",
      "    bind=True,",
      "    max_retries=${1:3},",
      "    default_retry_delay=${2:60},",
      "    autoretry_for=(${3:Exception},),",
      "    retry_backoff=True,",
      "    retry_backoff_max=600,",
      "    retry_jitter=True,",
      ")",
      "async def ${4:task_name}(self, ${5:param1}: ${6:str}, ${7:param2}: ${8:int}) -> ${9:Dict[str, Any]}:",
      "    \"\"\"${10:Task description}.",
      "",
      "    Args:",
      "        ${5:param1}: ${11:Parameter description}",
      "        ${7:param2}: ${12:Parameter description}",
      "",
      "    Returns:",
      "        ${13:Return value description}",
      "",
      "    Raises:",
      "        ${14:Exception}: ${15:When error occurs}",
      "    \"\"\"",
      "    logger.info(",
      "        \"task_started\",",
      "        task=\"${4:task_name}\",",
      "        task_id=self.request.id,",
      "        ${5:param1}=${5:param1},",
      "        ${7:param2}=${7:param2},",
      "    )",
      "",
      "    try:",
      "        # Task logic",
      "        ${16:result = await process_data(${5:param1}, ${7:param2})}",
      "",
      "        logger.info(",
      "            \"task_completed\",",
      "            task=\"${4:task_name}\",",
      "            task_id=self.request.id,",
      "        )",
      "",
      "        return ${17:{\\\"status\\\": \\\"success\\\", \\\"result\\\": result\\}}",
      "",
      "    except Exception as exc:",
      "        logger.exception(",
      "            \"task_failed\",",
      "            task=\"${4:task_name}\",",
      "            task_id=self.request.id,",
      "            error=str(exc),",
      "            retry_count=self.request.retries,",
      "        )",
      "",
      "        # Retry with exponential backoff",
      "        raise self.retry(exc=exc)",
      "$0"
    ]
  },

