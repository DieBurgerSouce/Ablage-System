  "Pydantic Schema": {
    "prefix": "schema-pydantic",
    "description": "Create Pydantic schemas for a model (Base, Create, Update, Response)",
    "body": [
      "\"\"\"${1:ModelName} Pydantic schemas.\"\"\"",
      "",
      "from datetime import datetime",
      "from typing import Optional, Dict, Any",
      "from pydantic import BaseModel, Field, UUID4, validator",
      "",
      "",
      "class ${1:ModelName}Base(BaseModel):",
      "    \"\"\"Base ${1:ModelName} schema with common fields.\"\"\"",
      "",
      "    ${2:name}: str = Field(..., min_length=1, max_length=255, description=\"${3:Field description}\")",
      "    ${4:description}: Optional[str] = Field(None, description=\"${5:Optional description}\")",
      "    ${6:status}: str = Field(default=\"${7:pending}\", description=\"${8:Status}\")",
      "",
      "",
      "class ${1:ModelName}Create(${1:ModelName}Base):",
      "    \"\"\"Schema for creating a new ${1:ModelName}.\"\"\"",
      "",
      "    @validator(\"${2:name}\")",
      "    def validate_${2:name}(cls, v: str) -> str:",
      "        \"\"\"Validate ${2:name} field.\"\"\"",
      "        if not v or not v.strip():",
      "            raise ValueError(\"${2:name} darf nicht leer sein\")",
      "        return v.strip()",
      "",
      "",
      "class ${1:ModelName}Update(BaseModel):",
      "    \"\"\"Schema for updating an existing ${1:ModelName}.\"\"\"",
      "",
      "    ${2:name}: Optional[str] = Field(None, min_length=1, max_length=255)",
      "    ${4:description}: Optional[str] = None",
      "    ${6:status}: Optional[str] = None",
      "",
      "",
      "class ${1:ModelName}Response(${1:ModelName}Base):",
      "    \"\"\"Schema for ${1:ModelName} API responses.\"\"\"",
      "",
      "    id: UUID4",
      "    ${9:owner_id}: UUID4",
      "    created_at: datetime",
      "    updated_at: datetime",
      "    ${10:metadata}: Optional[Dict[str, Any]] = None",
      "",
      "    class Config:",
      "        \"\"\"Pydantic config.\"\"\"",
      "",
      "        from_attributes = True",
      "        json_schema_extra = {",
      "            \"example\": {",
      "                \"id\": \"123e4567-e89b-12d3-a456-426614174000\",",
      "                \"${9:owner_id}\": \"123e4567-e89b-12d3-a456-426614174001\",",
      "                \"${2:name}\": \"${11:Example Name}\",",
      "                \"${4:description}\": \"${12:Example description}\",",
      "                \"${6:status}\": \"${7:pending}\",",
      "                \"created_at\": \"2024-01-01T00:00:00Z\",",
      "                \"updated_at\": \"2024-01-01T00:00:00Z\",",
      "                \"${10:metadata}\": {},",
      "            }",
      "        }",
      "$0"
    ]
  },

