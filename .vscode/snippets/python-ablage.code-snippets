  "Async OCR Agent Class": {
    "prefix": "agent-ocr",
    "description": "Create a complete async OCR agent class with GPU management",
    "body": [
      "\"\"\"${1:AgentName} - ${2:Agent description}.",
      "",
      "Handles ${3:specific OCR tasks}.",
      "\"\"\"",
      "",
      "from typing import Optional, Dict, Any, List",
      "import asyncio",
      "import structlog",
      "import torch",
      "from pathlib import Path",
      "",
      "from app.core.exceptions import OCRProcessingError, GPUOutOfMemoryError",
      "from app.utils.gpu_manager import GPUManager",
      "from app.schemas.ocr import OCRResult, DocumentMetadata",
      "",
      "logger = structlog.get_logger(__name__)",
      "",
      "",
      "class ${1:AgentName}:",
      "    \"\"\"${2:Agent description}.\"\"\"",
      "",
      "    def __init__(",
      "        self,",
      "        model_path: Optional[str] = None,",
      "        gpu_manager: Optional[GPUManager] = None,",
      "        batch_size: int = ${4:16},",
      "    ):",
      "        \"\"\"Initialize ${1:AgentName}.",
      "",
      "        Args:",
      "            model_path: Path to the model weights",
      "            gpu_manager: GPU resource manager instance",
      "            batch_size: Batch size for processing",
      "        \"\"\"",
      "        self.model_path = model_path or \"${5:default/model/path}\"",
      "        self.gpu_manager = gpu_manager or GPUManager()",
      "        self.batch_size = batch_size",
      "        self.model: Optional[torch.nn.Module] = None",
      "        self._initialized = False",
      "",
      "        logger.info(",
      "            \"agent_initialized\",",
      "            agent=\"${1:AgentName}\",",
      "            model_path=self.model_path,",
      "            batch_size=self.batch_size,",
      "        )",
      "",
      "    async def initialize(self) -> None:",
      "        \"\"\"Load model and initialize agent.\"\"\"",
      "        if self._initialized:",
      "            return",
      "",
      "        try:",
      "            # Load model",
      "            logger.info(\"loading_model\", model_path=self.model_path)",
      "            self.model = await self._load_model()",
      "            self.model.eval()",
      "",
      "            # Move to GPU if available",
      "            if torch.cuda.is_available():",
      "                self.model = self.model.cuda()",
      "",
      "                # Warm-up inference",
      "                with torch.no_grad():",
      "                    dummy_input = torch.randn(1, 3, 224, 224).cuda()",
      "                    _ = self.model(dummy_input)",
      "",
      "                logger.info(",
      "                    \"model_loaded_gpu\",",
      "                    gpu_name=torch.cuda.get_device_name(0),",
      "                    vram_allocated_gb=torch.cuda.memory_allocated() / 1024**3,",
      "                )",
      "",
      "            self._initialized = True",
      "",
      "        except Exception as e:",
      "            logger.exception(\"model_loading_failed\", error=str(e))",
      "            raise OCRProcessingError(f\"Failed to initialize ${1:AgentName}: {e}\") from e",
      "",
      "    async def _load_model(self) -> torch.nn.Module:",
      "        \"\"\"Load the model from disk.",
      "",
      "        Returns:",
      "            Loaded model instance",
      "        \"\"\"",
      "        # TODO: Implement model loading logic",
      "        ${6:raise NotImplementedError(\"Model loading not implemented\")}",
      "",
      "    async def process(self, image_path: Path) -> OCRResult:",
      "        \"\"\"Process a single image.",
      "",
      "        Args:",
      "            image_path: Path to the image file",
      "",
      "        Returns:",
      "            OCR processing result",
      "",
      "        Raises:",
      "            OCRProcessingError: If processing fails",
      "            GPUOutOfMemoryError: If GPU runs out of memory",
      "        \"\"\"",
      "        await self.initialize()",
      "",
      "        try:",
      "            # Load and preprocess image",
      "            image = await self._load_image(image_path)",
      "",
      "            # Process with GPU memory guard",
      "            with self.gpu_manager.memory_guard():",
      "                result = await self._process_image(image)",
      "",
      "            logger.info(",
      "                \"image_processed\",",
      "                image_path=str(image_path),",
      "                text_length=len(result.text),",
      "                confidence=result.confidence,",
      "            )",
      "",
      "            return result",
      "",
      "        except torch.cuda.OutOfMemoryError as e:",
      "            logger.error(\"gpu_oom\", image_path=str(image_path))",
      "            raise GPUOutOfMemoryError(f\"GPU OOM processing {image_path}\") from e",
      "        except Exception as e:",
      "            logger.exception(\"processing_failed\", image_path=str(image_path))",
      "            raise OCRProcessingError(f\"Failed to process {image_path}: {e}\") from e",
      "",
      "    async def process_batch(self, image_paths: List[Path]) -> List[OCRResult]:",
      "        \"\"\"Process multiple images in batches.",
      "",
      "        Args:",
      "            image_paths: List of image file paths",
      "",
      "        Returns:",
      "            List of OCR results",
      "        \"\"\"",
      "        await self.initialize()",
      "",
      "        results = []",
      "        for i in range(0, len(image_paths), self.batch_size):",
      "            batch = image_paths[i : i + self.batch_size]",
      "            batch_results = await asyncio.gather(*[self.process(path) for path in batch])",
      "            results.extend(batch_results)",
      "",
      "        return results",
      "",
      "    async def _load_image(self, image_path: Path) -> Any:",
      "        \"\"\"Load and preprocess image.\"\"\"",
      "        # TODO: Implement image loading",
      "        ${7:raise NotImplementedError(\"Image loading not implemented\")}",
      "",
      "    async def _process_image(self, image: Any) -> OCRResult:",
      "        \"\"\"Process image with the model.\"\"\"",
      "        # TODO: Implement image processing",
      "        ${8:raise NotImplementedError(\"Image processing not implemented\")}",
      "",
      "    async def cleanup(self) -> None:",
      "        \"\"\"Clean up resources.\"\"\"",
      "        if self.model is not None and torch.cuda.is_available():",
      "            torch.cuda.empty_cache()",
      "        self._initialized = False",
      "        logger.info(\"agent_cleanup_complete\", agent=\"${1:AgentName}\")",
      "$0"
