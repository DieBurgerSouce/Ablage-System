# Frontend Environment Configuration
# Kopiere diese Datei nach .env.local und passe die Werte an

# =============================================================================
# Loki Logging Integration
# =============================================================================

# Aktiviert das Senden von Frontend-Logs an Grafana Loki
# true = Logs werden an Loki gesendet (Production)
# false = Nur lokales Console-Logging (Development)
VITE_LOKI_ENABLED=false

# URL des Loki Push API Endpoints
# Standard: http://localhost:3100 (lokale Docker-Instanz)
VITE_LOKI_URL=http://localhost:3100

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL (normalerweise ueber Nginx Proxy)
# WICHTIG: Muss den /api/v1-Pfad ENTHALTEN — alle apiClient-Aufrufe sind
# relativ dazu (z. B. apiClient.get('/documents') -> <VITE_API_URL>/documents).
# VITE_API_URL=http://localhost:8000/api/v1
