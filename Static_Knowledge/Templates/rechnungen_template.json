{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deutsche Rechnung Template",
  "description": "Invoice schema compliant with §14 UStG (German VAT Act)",
  "type": "object",
  "priority": "P0",
  "document_type": "rechnung",
  "estimated_volume_percent": 65,
  "required": [
    "rechnungsnummer",
    "rechnungsdatum",
    "lieferant",
    "kunde",
    "positionen",
    "gesamt"
  ],
  "properties": {
    "rechnungsnummer": {
      "type": "string",
      "description": "Invoice number - must be unique and sequential (§14 Abs. 4 Nr. 4 UStG)",
      "pattern": "^[0-9]{4}-[0-9]{3,6}$",
      "examples": [
        "2024-001",
        "2024-042",
        "2023-12345"
      ],
      "extraction_hints": {
        "keywords": [
          "Rechnungsnummer",
          "Rechnung-Nr",
          "Invoice No",
          "RE-Nr"
        ],
        "position": "top_third",
        "confidence_threshold": 0.95
      }
    },
    "rechnungsdatum": {
      "type": "string",
      "format": "date",
      "description": "Invoice date (§14 Abs. 4 Nr. 3 UStG)",
      "pattern": "^(0[1-9]|[12][0-9]|3[01])\\.(0[1-9]|1[0-2])\\.\\d{4}$",
      "examples": [
        "22.11.2024",
        "01.01.2024"
      ],
      "extraction_hints": {
        "keywords": [
          "Rechnungsdatum",
          "Datum",
          "Date"
        ],
        "formats": [
          "DD.MM.YYYY",
          "DD. Month YYYY"
        ]
      }
    },
    "leistungsdatum": {
      "type": "string",
      "format": "date",
      "description": "Date of service/delivery (optional but recommended)",
      "examples": [
        "15.11.2024",
        "November 2024"
      ],
      "extraction_hints": {
        "keywords": [
          "Leistungsdatum",
          "Lieferdatum",
          "Leistungszeitraum"
        ]
      }
    },
    "lieferant": {
      "type": "object",
      "description": "Supplier information (§14 Abs. 4 Nr. 1 UStG)",
      "required": [
        "name",
        "adresse"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Company name with legal form",
          "examples": [
            "Musterfirma GmbH",
            "Müller & Söhne KG",
            "Schmidt GbR"
          ],
          "extraction_hints": {
            "position": "header",
            "legal_forms": [
              "GmbH",
              "AG",
              "KG",
              "OHG",
              "GbR",
              "UG",
              "e.K.",
              "PartG"
            ]
          }
        },
        "adresse": {
          "type": "object",
          "properties": {
            "strasse": {
              "type": "string",
              "examples": [
                "Hauptstraße 123"
              ]
            },
            "plz": {
              "type": "string",
              "pattern": "^[0-9]{5}$",
              "examples": [
                "12345"
              ]
            },
            "ort": {
              "type": "string",
              "examples": [
                "München",
                "Köln"
              ]
            }
          }
        },
        "steuernummer": {
          "type": "string",
          "description": "Tax number or USt-IdNr (§14 Abs. 4 Nr. 2 UStG)",
          "oneOf": [
            {
              "pattern": "^[0-9]{2}/[0-9]{3}/[0-9]{5}$",
              "description": "Steuernummer format"
            },
            {
              "pattern": "^DE[0-9]{9}$",
              "description": "USt-IdNr format"
            }
          ],
          "examples": [
            "12/345/67890",
            "DE123456789"
          ],
          "extraction_hints": {
            "keywords": [
              "Steuernummer",
              "St.-Nr.",
              "USt-IdNr.",
              "USt-ID"
            ],
            "confidence_threshold": 0.99
          }
        },
        "kontakt": {
          "type": "object",
          "properties": {
            "telefon": {
              "type": "string",
              "pattern": "^(\\+49|0)[0-9\\s\\-/]+$"
            },
            "email": {
              "type": "string",
              "format": "email"
            },
            "website": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "bankverbindung": {
          "type": "object",
          "description": "Bank details for payment",
          "properties": {
            "iban": {
              "type": "string",
              "pattern": "^DE[0-9]{20}$",
              "examples": [
                "DE89370400440532013000"
              ],
              "extraction_hints": {
                "keywords": [
                  "IBAN",
                  "Bankverbindung"
                ],
                "gdpr_sensitive": true
              }
            },
            "bic": {
              "type": "string",
              "pattern": "^[A-Z]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
              "examples": [
                "COBADEFFXXX"
              ]
            },
            "bank_name": {
              "type": "string",
              "examples": [
                "Commerzbank"
              ]
            }
          }
        }
      }
    },
    "kunde": {
      "type": "object",
      "description": "Customer information (§14 Abs. 4 Nr. 1 UStG)",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "extraction_hints": {
            "keywords": [
              "Kunde",
              "Rechnungsempfänger",
              "An:",
              "Empfänger"
            ],
            "position": "upper_third"
          }
        },
        "kundennummer": {
          "type": "string",
          "examples": [
            "K-12345"
          ]
        },
        "adresse": {
          "type": "object",
          "properties": {
            "strasse": {
              "type": "string"
            },
            "plz": {
              "type": "string",
              "pattern": "^[0-9]{5}$"
            },
            "ort": {
              "type": "string"
            }
          }
        }
      }
    },
    "positionen": {
      "type": "array",
      "description": "Invoice line items (§14 Abs. 4 Nr. 5-6 UStG)",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "bezeichnung",
          "menge",
          "einzelpreis",
          "gesamt"
        ],
        "properties": {
          "position_nr": {
            "type": "integer",
            "minimum": 1
          },
          "bezeichnung": {
            "type": "string",
            "description": "Item description",
            "examples": [
              "Beratungsleistung",
              "Softwarelizenz",
              "Materialkosten"
            ]
          },
          "menge": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "einheit": {
            "type": "string",
            "examples": [
              "Stk",
              "h",
              "Psch",
              "kg",
              "m"
            ]
          },
          "einzelpreis": {
            "type": "number",
            "description": "Unit price in EUR (net)",
            "minimum": 0
          },
          "gesamt": {
            "type": "number",
            "description": "Line total in EUR (net)"
          },
          "steuersatz": {
            "type": "number",
            "description": "VAT rate in percent",
            "enum": [
              0,
              7,
              19
            ]
          }
        }
      },
      "extraction_hints": {
        "table_detection": true,
        "column_headers": [
          "Pos",
          "Position",
          "Bezeichnung",
          "Menge",
          "Einzelpreis",
          "Gesamt"
        ]
      }
    },
    "gesamt": {
      "type": "object",
      "description": "Total amounts (§14 Abs. 4 Nr. 7 UStG)",
      "required": [
        "netto",
        "mwst_betrag",
        "brutto"
      ],
      "properties": {
        "netto": {
          "type": "number",
          "description": "Net amount in EUR",
          "minimum": 0,
          "extraction_hints": {
            "keywords": [
              "Netto",
              "Zwischensumme",
              "Summe netto",
              "Nettobetrag"
            ],
            "format": "1.234,56 €"
          }
        },
        "mwst_satz": {
          "type": "number",
          "description": "VAT rate in percent",
          "enum": [
            0,
            7,
            19
          ],
          "extraction_hints": {
            "keywords": [
              "MwSt.",
              "USt.",
              "Mehrwertsteuer",
              "Umsatzsteuer"
            ]
          }
        },
        "mwst_betrag": {
          "type": "number",
          "description": "VAT amount in EUR",
          "minimum": 0,
          "extraction_hints": {
            "keywords": [
              "zzgl. MwSt.",
              "zzgl. 19% MwSt.",
              "Steuerbetrag"
            ]
          }
        },
        "brutto": {
          "type": "number",
          "description": "Gross amount in EUR",
          "minimum": 0,
          "extraction_hints": {
            "keywords": [
              "Brutto",
              "Gesamtbetrag",
              "Rechnungsbetrag",
              "Endbetrag"
            ],
            "position": "bottom_third",
            "confidence_threshold": 0.98
          }
        },
        "zahlungsziel": {
          "type": "string",
          "description": "Payment deadline",
          "examples": [
            "14 Tage",
            "30 Tage netto",
            "06.12.2024"
          ],
          "extraction_hints": {
            "keywords": [
              "Zahlbar bis",
              "Zahlungsziel",
              "Fällig am",
              "Zahlbar innerhalb"
            ]
          }
        },
        "verwendungszweck": {
          "type": "string",
          "description": "Payment reference",
          "examples": [
            "Rechnung 2024-042"
          ]
        }
      }
    },
    "bemerkungen": {
      "type": "array",
      "description": "Additional notes and legal text",
      "items": {
        "type": "string"
      },
      "examples": [
        "Kleinunternehmerregelung gem. §19 UStG - keine Umsatzsteuer ausgewiesen",
        "Reverse Charge - Steuerschuldnerschaft des Leistungsempfängers",
        "Zahlung erfolgt unter Eigentumsvorbehalt"
      ]
    }
  },
  "validation_rules": {
    "gesamt_calculation": {
      "description": "Validate that netto + mwst_betrag = brutto",
      "formula": "gesamt.netto + gesamt.mwst_betrag ≈ gesamt.brutto",
      "tolerance": 0.02
    },
    "mwst_calculation": {
      "description": "Validate VAT calculation",
      "formula": "gesamt.netto * (gesamt.mwst_satz / 100) ≈ gesamt.mwst_betrag",
      "tolerance": 0.01
    },
    "positionen_sum": {
      "description": "Sum of line items should equal net total",
      "formula": "sum(positionen[*].gesamt) ≈ gesamt.netto",
      "tolerance": 0.01
    },
    "pflichtangaben_§14_ustg": {
      "description": "Check mandatory fields per §14 UStG",
      "required_fields": [
        "rechnungsnummer",
        "rechnungsdatum",
        "lieferant.name",
        "lieferant.adresse",
        "lieferant.steuernummer",
        "kunde.name",
        "positionen",
        "gesamt.netto",
        "gesamt.mwst_betrag",
        "gesamt.brutto"
      ]
    }
  },
  "post_processing": {
    "german_normalization": true,
    "umlaut_validation": true,
    "date_format_validation": true,
    "currency_format": "de_DE",
    "number_format": "1.234,56"
  },
  "gdpr_compliance": {
    "sensitive_fields": [
      "kunde.name",
      "kunde.adresse",
      "lieferant.bankverbindung.iban"
    ],
    "retention_period_years": 10,
    "legal_basis": "§147 AO (Aufbewahrungspflicht)"
  }
}
