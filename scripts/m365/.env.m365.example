# .env.m365 — Zugangsdaten der M365-Extraktion (Projekt „Firmen-E-Mail-Gedaechtnis")
# --------------------------------------------------------------------------------
# Vorlage. Kopiere diese Datei nach:  E:\m365_staging\secrets\.env.m365
# und trage die echten Werte ein. NIEMALS ins Git committen (siehe .gitignore).
# Vollstaendige Anleitung: RUNBOOK_P0_BEN.md
#
# Fundort der Datei zur Laufzeit (in dieser Reihenfolge):
#   1) Umgebungsvariable M365_ENV_FILE (expliziter Pfad)
#   2) <STAGING_ROOT>\secrets\.env.m365
#   3) scripts\m365\.env.m365

# --- Entra-App (PFLICHT) ---------------------------------------------------------
# entra.microsoft.com -> App-Registrierungen -> ablage-m365-extract -> Uebersicht
M365_TENANT_ID=00000000-0000-0000-0000-000000000000
M365_CLIENT_ID=00000000-0000-0000-0000-000000000000

# --- Anmeldung: ENTWEDER Zertifikat (empfohlen) ODER Client-Secret ---------------
# Variante A (empfohlen): Zertifikat.
#   M365_CERT_PATH        = Pfad zur PEM-Datei mit PRIVATEM Schluessel (ohne Passphrase)
#   M365_CERT_THUMBPRINT  = SHA-1-Thumbprint des Zertifikats (aus der App bzw. $cert.Thumbprint)
M365_CERT_PATH=E:\m365_staging\secrets\ablage-m365.pem
M365_CERT_THUMBPRINT=

# Variante B (Fallback): Client-Secret (12 Monate). NUR setzen, wenn KEIN Zertifikat.
M365_CLIENT_SECRET=

# --- Staging (PFLICHT fuer Extraktion; Inventur nutzt Fallback = aktuelles Verz.) --
# Zielverzeichnis auf der externen SSD (Ben-Entscheid E-S1). Hier landen Logs & Reports.
STAGING_ROOT=E:\m365_staging

# --- Optional --------------------------------------------------------------------
# Expliziter Pfad zu DIESER Datei (ueberschreibt die Auto-Suche oben):
# M365_ENV_FILE=E:\m365_staging\secrets\.env.m365
