# Ablage-System .dockerignore
# Excludes files from Docker build context for faster builds and smaller images

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
env/
ENV/
.venv/
env.bak/
venv.bak/

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.log
.hypothesis/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Linting
.ruff_cache/
.pylint.d/

# IDEs
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
*.iml
.project
.classpath
.settings/
.metadata/

# Git
.git/
.gitignore
.gitattributes
.github/

# Documentation (don't need in container)
docs/
*.md
!README.md
!CHANGELOG.md
*.rst

# CI/CD
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml
Jenkinsfile
.circleci/

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Environment files (use .env.example instead)
.env
.env.*
!.env.example

# Logs
logs/
*.log
log/

# Data directories (mount as volumes instead)
data/
uploads/
processed/
exports/
backups/

# Database files
*.db
*.sqlite
*.sqlite3
db.sqlite3

# OS
Thumbs.db
.DS_Store
desktop.ini
$RECYCLE.BIN/

# Jupyter
.ipynb_checkpoints/
notebooks/
*.ipynb

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo

# Build artifacts
*.tar.gz
*.zip
*.rar

# Infrastructure (not needed in app container)
infrastructure/
terraform/
ansible/
k8s/
kubernetes/

# Scripts (most not needed in container)
scripts/
!scripts/docker-entrypoint.sh
!scripts/wait-for-it.sh

# Tests (don't need in production image)
tests/
test/
*_test.py
test_*.py

# Development tools
.pre-commit-config.yaml
.editorconfig
.markdownlint.json
.yamllint.yml
.secrets.baseline
Makefile

# Node (if frontend exists)
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# Cache directories
.cache/
*.cache/

# Monitoring & profiling
.nyc_output/
.coverage/
*.prof

# Security scans
bandit.json
safety.json
trivy-report.json

# Large files that shouldn't be in image
*.pdf
*.png
*.jpg
*.jpeg
*.gif
*.mp4
*.avi
*.mov

# DevContainer
.devcontainer/

# Claude Code
.claude/
CLAUDE.md

# Round summaries and status files
ROUND_*.md
*_SUMMARY.md
*_STATUS.md
*_PROGRESS.md
PHASE_*.md
IMPLEMENTATION_STATUS.md
KNOWLEDGE_ARCHITECTURE*.md
OPERATIONAL_EXCELLENCE_PACKAGE.md

# Backup files
*.bak
*.backup
*~
