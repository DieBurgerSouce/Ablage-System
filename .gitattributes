# Auto-detect text files and normalize line endings
* text=auto

# Python - always LF
*.py text eol=lf
*.pyi text eol=lf
*.pyx text eol=lf

# Shell scripts - must be LF (Docker/Linux)
*.sh text eol=lf
*.bash text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Web files - LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Markdown - LF
*.md text eol=lf

# Config files - LF
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Windows batch files - CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files - no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.pt binary
*.pth binary
*.bin binary
*.whl binary
*.zip binary
*.tar.gz binary
*.model binary
*.onnx binary
*.safetensors binary

# Fonts
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
