- Modell: {{ model }}
- Baujahr: {{ year }}
- Kilometerstand: {{ mileage_km }} km
- Antrieb: {{ fuel_type }}
- Fahrzeugtyp: {{ vehicle_type }}
{% if purchase_price > 0 %}
