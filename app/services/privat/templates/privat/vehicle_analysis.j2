    "remaining_value_percent": <Restwert in Prozent vom Neupreis>,
    "optimal_sell_timeframe": "<optimaler Verkaufszeitraum, z.B. 'innerhalb 6 Monate'>",
    "market_demand": "<hoch|mittel|gering>",
    "value_factors": [
        "<Faktor 1 der den Wert beeinflusst>",
