# ============================================================
# Ablage-System Environment Variables
# ============================================================
# WICHTIG: Kopiere diese Datei nach .env und setze ALLE Werte!
# Generiere sichere Passwörter mit: openssl rand -base64 32
# ============================================================

# ============================================================
# PFLICHT-VARIABLEN (ohne diese startet das System nicht!)
# ============================================================

# Database (PostgreSQL)
POSTGRES_DB=ablage_system
POSTGRES_USER=ablage_admin
# PFLICHT: Generiere mit: openssl rand -base64 24
DB_PASSWORD=

# Postgres-TLS-Modus (disable|allow|prefer|require|verify-ca|verify-full).
# Wird NICHT als ?sslmode=-Query an DATABASE_URL gehaengt (asyncpg kennt das
# nicht; pgbouncer-Config-Generator crasht daran), sondern von docker-compose
# an pgbouncer (SERVER_TLS_SSLMODE) und postgres_exporter durchgereicht.
# M-42 (Phase 0): Der Default-Compose startet Postgres OHNE ssl=on
# (Container-internes Netz, kein externer Zugriff) — 'prefer' faellt dabei
# sauber auf unverschluesselt zurueck. Nur bei extern erreichbarem Postgres
# TLS reaktivieren (docker-compose.yml + pg_hba.conf) und 'require' setzen.
DB_SSL_MODE=prefer

# ------------------------------------------------------------
# RLS light (Neuausrichtung Phase 7, OPT-IN): App-DB-Rolle ohne
# Superuser/BYPASSRLS, damit die vorhandenen Row-Level-Security-
# Policies (app.current_company_id) auf DB-Ebene greifen.
#
# WARNUNG: Erst aktivieren, NACHDEM
#   1. scripts/db/create_app_role.sql als Superuser ausgefuehrt wurde
#      (legt Rolle 'ablage_app' an + GRANTs + DEFAULT PRIVILEGES) und
#   2. der Login + ein Smoke-Test (Login, Upload, Suche) gegen die
#      neue Rolle getestet ist (Verifikations-SQL im Skript-Kommentar:
#      SET ROLE ablage_app; SELECT count(*) FROM documents; => 0 ohne Kontext).
# Ohne diese beiden Variablen laeuft alles unveraendert als POSTGRES_USER
# (Superuser) — auskommentiert lassen = heutiges Verhalten.
# Rollback: beide Variablen wieder auskommentieren + Container neu starten.
#POSTGRES_APP_USER=ablage_app
# Generiere mit: openssl rand -base64 24
#POSTGRES_APP_PASSWORD=

# MinIO Object Storage
# PFLICHT: Mindestens 8 Zeichen, keine Default-Werte verwenden!
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# JWT Security
# PFLICHT: Generiere mit: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Monitoring (Grafana)
# PFLICHT: Sichere Credentials setzen!
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# ============================================================
# OPTIONALE VARIABLEN (mit sicheren Defaults)
# ============================================================

# Redis (optional: Passwort für zusätzliche Sicherheit)
# Generiere mit: openssl rand -base64 24
REDIS_PASSWORD=

# Connection URLs (automatisch generiert, nur ändern wenn nötig)
# DATABASE_URL wird automatisch aus POSTGRES_* Variablen generiert
# REDIS_URL wird automatisch generiert

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
# GPU Memory Limit in GB (85% von 16GB = 13.6GB für RTX 4080)
GPU_MEMORY_LIMIT_GB=13.6

# Application Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=INFO
# ⚠️ NIEMALS true in Produktion: DEBUG lockert CORS/TrustedHosts und bypasste
# historisch die 2FA fuer Admin-Rollen (W1-001, P0). Seit W1-001 neutralisiert
# app/core/config.py DEBUG=true bei ENVIRONMENT=production automatisch und der
# 2FA-Bypass haengt ausschliesslich an TESTING (nie in Produktion aktiv) —
# trotzdem hier immer false lassen; fuer Tests TESTING=true nutzen.
DEBUG=false

# CORS-Origins (R8 / M-14): Browser-Origins, die auf die API zugreifen duerfen.
# Format: JSON-Liste (pydantic List[str], siehe app/core/config.py CORS_ORIGINS).
# In Produktion (DEBUG=false) PFLICHT und nur https:// erlaubt — leere Liste
# bedeutet: kein Browser-Origin zugelassen. Fuer das LAN-TLS-Setup:
CORS_ORIGINS=["https://ablage.firmenich.lan"]

# JWT Token Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_DOCUMENTS_PER_HOUR=10
DEFAULT_USER_DAILY_QUOTA=100

# Rate Limit Tiers
RATE_LIMIT_FREE_HOURLY=10
RATE_LIMIT_FREE_DAILY=50
RATE_LIMIT_PREMIUM_HOURLY=100
RATE_LIMIT_PREMIUM_DAILY=1000
RATE_LIMIT_ADMIN_HOURLY=10000

# Rate Limit Windows (in seconds)
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_REGISTER_ATTEMPTS=3
RATE_LIMIT_REGISTER_WINDOW=3600

# Rate Limit Whitelist (comma-separated IPs)
# RATE_LIMIT_WHITELIST=127.0.0.1,::1,10.0.0.1

# ============================================================
# VAULT CONFIGURATION (Optional - für Production empfohlen)
# Dokumentation: infrastructure/vault/README.md
# Setup: ./infrastructure/vault/setup-vault-complete.sh setup
# ============================================================
VAULT_ENABLED=false

# Vault Server Adresse (HTTPS für Production!)
VAULT_ADDR=https://vault:8200

# Authentifizierung: ENTWEDER Token ODER AppRole verwenden
# Option 1: Token-basierte Authentifizierung (für Development)
VAULT_TOKEN=

# Option 2: AppRole-Authentifizierung (für Production empfohlen)
# Generiert durch: ./infrastructure/vault/setup-vault-complete.sh setup
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# Vault Namespace (nur für Vault Enterprise)
VAULT_NAMESPACE=

# Pfad zu den Ablage-System Secrets in Vault
VAULT_SECRET_PATH=ablage-system
VAULT_MOUNT_POINT=secret

# TLS Konfiguration
# VAULT_CACERT wird automatisch gesetzt auf: /app/certs/ca.crt
# Verification überspringen NUR für Development ohne TLS!
VAULT_SKIP_VERIFY=false
VAULT_VERIFY_SSL=true

# Secret-Refresh-Intervall in Sekunden (für Runtime-Rotation)
VAULT_SECRET_REFRESH_INTERVAL=300

# ============================================================
# ALERTING (Optional)
# ============================================================
# Email Alerts
# Hinweis (Task D, 2026-05-19): SMTP_PASSWORD wird NICHT mehr ueber .env
# in den Alertmanager-Container injiziert. Stattdessen file-mount-Pattern
# (analog Slack/G01). Setup:
#   echo 'DEIN_SMTP_PASSWORD' > infrastructure/alerting/smtp-password
#   chmod 600 infrastructure/alerting/smtp-password
#   docker-compose restart alertmanager
# Datei ist in .gitignore und wird readonly gemountet auf
# /etc/alertmanager/smtp-password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alertmanager@ablage-system.local
EMAIL_RECIPIENTS=ops-team@internal.local

# Microsoft Teams Webhook
TEAMS_WEBHOOK_URL=

# Slack Alerts (Sprint 0 / G01)
# Empfohlener Weg fuer den ALERTMANAGER: Webhook-URL als Datei mounten unter
#   infrastructure/alerting/slack-webhook.url   (eine Zeile, kein Newline am Ende)
# Diese Datei ist in .gitignore und wird vom alertmanager-Container read-only gemountet.
# Erstellung: https://api.slack.com/apps -> "Incoming Webhooks" -> Add to Workspace
# Channel-Empfehlung: #ablage-alerts (privat)
#
# M-01 (Phase 0): App-interne Slack-Integration (app/core/config.py ->
# slack_service). SLACK_WEBHOOK_URL wird auch von der App gelesen
# (Benachrichtigungen/Alert Center an den Kanal #ablage-alerts).
# Platzhalter-Beispiel:
#   SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_WEBHOOK_URL=
# App-interne Slack-Benachrichtigungen aktivieren (M-01).
# Voraussetzung: SLACK_WEBHOOK_URL oben gesetzt.
SLACK_ENABLED=true
# Standard-Kanal fuer App-Benachrichtigungen (ohne #), z. B. Kanal #ablage-alerts:
SLACK_DEFAULT_CHANNEL=ablage-alerts

# Sentry (Sprint 0 / G10)
# Erstellung: https://sentry.io -> Projekt "ablage-system-pilot" -> DSN kopieren
# (Alternativ selfhosted Sentry im docker-compose.alerting.yml)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ENABLE_TRACING=true
ENVIRONMENT=production
VERSION=0.1.0

# External URLs für Alerts
ALERTMANAGER_EXTERNAL_URL=http://localhost:9093
GRAFANA_ROOT_URL=http://localhost:3000

# ============================================================
# MONITORING (Optional)
# ============================================================
FLOWER_USER=admin
FLOWER_PASSWORD=
PGADMIN_EMAIL=admin@ablage-system.local
PGADMIN_PASSWORD=

# ============================================================
# RAG INTELLIGENCE LAYER
# ============================================================
# Model Services (HuggingFace Text Embeddings Inference)
# Diese Services laufen via docker-compose.rag.yaml
EMBEDDING_SERVICE_URL=http://embedding-service:8080
RERANKER_SERVICE_URL=http://reranker-service:8080

# M-35 (Neuausrichtung Phase 6): Device fuer Query-Embeddings (cpu|cuda|auto).
# - Backend/API-Prozess: "cpu" (Default in docker-compose) — e5-large-Query
#   kostet auf CPU nur ~50-150 ms und die GPU bleibt exklusiv fuer OCR frei.
# - GPU-Worker: WORKER_EMBEDDING_DEVICE steuert dessen EMBEDDING_DEVICE
#   (Default "auto" = GPU falls verfuegbar) — Batch-Embeddings (Beat
#   semantic-batch-embed 04:15) bleiben damit auf der GPU.
EMBEDDING_DEVICE=cpu
WORKER_EMBEDDING_DEVICE=auto

# Ollama LLM Service
OLLAMA_URL=http://ollama:11434
OLLAMA_KEEP_ALIVE=24h

# LLM Model Selection
# Realtime: Schnelle Antworten (< 15s) fuer Chat
DEFAULT_LLM_REALTIME=qwen3:8b-q4_K_M
# Analysis: Tiefgehende Analyse (< 60s) fuer Reports
DEFAULT_LLM_ANALYSIS=qwen3:14b-q4_K_M
# Max parallele LLM-Anfragen
LLM_MAX_CONCURRENT_REQUESTS=4

# Document Chunking
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_CHUNK_MIN_SIZE=100
RAG_CHUNK_MAX_SIZE=2048

# Customer Cards
RAG_CUSTOMER_CARD_CONTEXT_CHUNKS=10

# Search Settings
RAG_SEARCH_DEFAULT_LIMIT=20
RAG_SEARCH_SEMANTIC_THRESHOLD=0.7
RAG_HYBRID_SEMANTIC_WEIGHT=0.7
RAG_HYBRID_KEYWORD_WEIGHT=0.3

# ============================================================
# SECURITY: ClamAV Malware Scanning
# ============================================================
# Malware-Scanning fuer Document Uploads (empfohlen: true)
MALWARE_SCAN_ENABLED=true

# Bei Scanner-Fehler Upload blockieren (fail-closed, empfohlen fuer Production)
MALWARE_SCAN_FAIL_CLOSED=true

# ClamAV Daemon Konfiguration (Docker-Netzwerk)
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=60
CLAMAV_MAX_SIZE_MB=100

# ============================================================
# SECURITY: Qdrant Vector Database API-Authentifizierung
# ============================================================
# OPTIONAL: API-Key fuer Qdrant (empfohlen in Production)
# Generiere mit: openssl rand -hex 32
# Leer lassen = Qdrant laeuft ohne Authentifizierung
QDRANT_API_KEY=

# Qdrant ist per Default deaktiviert (nutzt pgvector)
# Neuausrichtung Phase 6 (2026-07): Suche konsolidiert auf pgvector; der
# qdrant-/reranker-Container startet nur noch ueber das Compose-Profil
# "qdrant-legacy" (docker compose --profile qdrant-legacy up -d).
# Reaktivierung erfordert QDRANT_ENABLED=true UND das Profil.
QDRANT_ENABLED=false

# ============================================================
# SECURITY: Metrics-Scrape-Token (Prometheus /internal-Endpoints)
# ============================================================
# W1-022: Schuetzt /api/v1/metrics/internal* vor unauthentisiertem Zugriff.
# Generiere mit: openssl rand -hex 32
# - Dev/Test: leer lassen -> Backend erlaubt Scraping ohne Token (bequem lokal).
# - PRODUKTION: PFLICHT. Ohne Token liefern die /internal-Endpoints 503.
# Der Wert MUSS mit der Prometheus-Token-Datei uebereinstimmen
# (infrastructure/prometheus/metrics_scrape_token, siehe dortige README.md).
METRICS_SCRAPE_TOKEN=

# ============================================================
# DISTRIBUTED TRACING (OpenTelemetry)
# ============================================================
# Aktiviert OpenTelemetry Tracing mit OTLP-Export
TRACING_ENABLED=true

# OTLP Endpoint (Jaeger Collector)
OTLP_ENDPOINT=jaeger:4317

# Console Export fuer lokales Debugging (false in Production)
TRACING_CONSOLE_EXPORT=false

# ============================================================
# DATABASE POOL (Erweiterte Konfiguration)
# ============================================================
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_MAX_OVERFLOW=40

# ============================================================
# BACKPRESSURE (Ueberlastschutz)
# ============================================================
BACKPRESSURE_ENABLED=true
BACKPRESSURE_QUEUE_THRESHOLD_WARNING=50
BACKPRESSURE_QUEUE_THRESHOLD_CRITICAL=100
BACKPRESSURE_QUEUE_THRESHOLD_REJECT=200

# ============================================================
# INPUT SANITIZATION (Eingabe-Validierung)
# ============================================================
INPUT_MAX_FILENAME_LENGTH=255
INPUT_MAX_PATH_LENGTH=1024
INPUT_MAX_QUERY_LENGTH=500
INPUT_MAX_TAG_LENGTH=100

# ============================================================
# YARA MALWARE SCANNER (Erweitert)
# ============================================================
# Zusaetzlich zum ClamAV Scanner oben
YARA_ENABLED=true
YARA_RULES_DIR=/etc/yara/rules
HASH_BLOCKLIST_FILE=/etc/yara/blocklist.txt
QUARANTINE_DIR=/var/quarantine

# ============================================================
# BACKUP
# ============================================================
BACKUP_DIR=/var/backups/ablage

# ============================================================
# INFRASTRUCTURE — Connection URLs (Optional Overrides)
# ============================================================
# Hinweis: Werden normalerweise automatisch aus POSTGRES_*/REDIS_* generiert.
# Nur setzen, wenn explizit gegen externe Services connected werden soll.

# PostgreSQL Connection-String (auto-derived aus POSTGRES_*; leer lassen = Default)
# Format: postgresql+asyncpg://USER:PASS@HOST:5432/DB
DATABASE_URL=

# Redis Connection-String (auto-derived aus REDIS_PASSWORD; leer lassen = Default)
# Format: redis://[:PASSWORD@]HOST:PORT/DB
REDIS_URL=

# Celery Broker + Result-Backend (default: Redis DB 0)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================================
# INFRASTRUCTURE — MinIO Object Storage Connection
# ============================================================
# Hinweis: MINIO_ROOT_USER/PASSWORD oben sind nur fuer Bootstrap.
# Anwendung connected via folgende dedizierte Credentials.

MINIO_ENDPOINT=minio:9000
# Access-Key (i.d.R. identisch mit MINIO_ROOT_USER)
MINIO_ACCESS_KEY=
# Secret-Key (i.d.R. identisch mit MINIO_ROOT_PASSWORD)
MINIO_SECRET_KEY=
# TLS-Verbindung aktivieren (Production: true)
MINIO_SECURE=false

# ============================================================
# VECTOR-DB — Qdrant Detailed Config
# ============================================================
# Hinweis: Nur relevant wenn QDRANT_ENABLED=true (oben).

QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
# gRPC bevorzugt fuer Performance (Production: true)
QDRANT_PREFER_GRPC=true

# Collection-Namen (per Service)
QDRANT_COLLECTION_DOCUMENTS=ablage_documents
QDRANT_COLLECTION_CHUNKS=ablage_chunks

# ============================================================
# VECTOR-DB — Dual-Write & A/B-Testing (Migration pgvector -> Qdrant)
# ============================================================
# Dual-Write: Schreibt parallel zu pgvector UND Qdrant waehrend Migration
VECTOR_DUAL_WRITE_ENABLED=false
# Async-Write: Qdrant-Writes im Background-Worker (empfohlen)
VECTOR_DUAL_WRITE_ASYNC=true
# Batch-Size fuer Bulk-Migration
VECTOR_MIGRATION_BATCH_SIZE=100

# A/B-Testing zwischen Vector-Backends
VECTOR_AB_TESTING_ENABLED=false
VECTOR_AB_CONTROL_BACKEND=pgvector
VECTOR_AB_CONTROL_EMBEDDING=intfloat/multilingual-e5-large
VECTOR_AB_TREATMENT_BACKEND=qdrant
VECTOR_AB_TREATMENT_EMBEDDING=intfloat/multilingual-e5-large
# Traffic-Split fuer Treatment-Gruppe (0-100, Prozent)
VECTOR_AB_TRAFFIC_SPLIT=10
VECTOR_AB_METRICS_ENABLED=true

# ============================================================
# OCR / GPU — Performance & Limits
# ============================================================
# GPU-Beschleunigung aktivieren (RTX 4080 empfohlen)
ENABLE_GPU=true
# Anteil des VRAM, den OCR-Backends maximal belegen (0.0-1.0)
GPU_MEMORY_FRACTION=0.85
# Max. Dateigroesse pro Upload (MB)
MAX_FILE_SIZE_MB=50
# Max. Seiten pro Dokument (DoS-Schutz)
MAX_PAGES_PER_DOCUMENT=100
# OCR-Timeout pro Dokument (Sekunden)
OCR_TIMEOUT_SECONDS=300

# Deutsche Sprach-Validierung (CLAUDE.md Rule 2)
GERMAN_VALIDATION_ENABLED=true
# Minimaler Score (0.0-1.0) fuer akzeptierte Erkennung
MINIMUM_GERMAN_VALIDATION_SCORE=0.7

# ============================================================
# SECURITY — Rate-Limit Fail-Mode
# ============================================================
# Wenn Redis ausfaellt: Standard-Endpoints fail-open (false) oder fail-closed (true)
RATE_LIMIT_FAIL_CLOSED=false
# Kritische Endpoints (Login, Password-Reset): empfohlen fail-closed=true
RATE_LIMIT_FAIL_CLOSED_CRITICAL=true

# ============================================================
# MONITORING — Prometheus Basic-Auth
# ============================================================
# Schuetzt /metrics-Endpoint vor unauthorisiertem Scraping
PROMETHEUS_USER=prometheus_admin
# PFLICHT: Generiere mit: openssl rand -base64 24
PROMETHEUS_PASSWORD=

# Slack-Webhook fuer Alerts: siehe ALERTING-Section oben (file-mount, nicht env)

# ============================================================
# BANKING / FinTS Auto-Sync (Remediation-Strom G4)
# ============================================================
# Guard, ob der FinTS-Mock-Sync echte Reconciliation/Buchung ausloesen darf.
# Default false = reiner Trockenlauf (keine echten Buchungen/Abgleiche).
FINTS_ALLOW_MOCK_SYNC=false
# Ob der automatische Bank-Sync-Beat (periodischer FinTS-Abgleich) aktiv ist.
# Default false = kein automatischer Sync, bis bewusst aktiviert.
FINTS_AUTO_SYNC_ENABLED=false

# ============================================================
# ODOO-INTEGRATION (Spiegel + Vendor-Bill-Push, Go-Live-Runbook)
# ============================================================
# Odoo-interne Company-ID fuer Mirror UND Push (AP-2). Spargelmesser = 2.
# Ohne Wert ueberspringt der Mirror die Connection STILL und der Push
# laeuft ohne Company-Context. Per-Connection-Override moeglich via
# OdooSyncStatus.sync_state["odoo_company_id"] (hat Vorrang, Folie-Szenario).
ODOO_MIRROR_COMPANY_ID=2
# Push von Entwurfs-Lieferantenrechnungen nach Odoo. ERST aktivieren, wenn
# das Phase-2-Gate gruen ist (scripts/odoo_golive_check.py --phase2) —
# Runbook Schritt A6. Wirkt erst nach Container-Neustart (--force-recreate).
ODOO_VENDOR_BILL_PUSH_ENABLED=false
# Optional: RFC-3161-Zeitstempel je Spiegel-Dokument (Runbook E-7: default aus)
# ODOO_MIRROR_USE_TSA=false

# ============================================================
# DEVELOPMENT ONLY (Nicht in Production verwenden!)
# ============================================================
# Für lokale Entwicklung ohne TLS
# VAULT_SKIP_VERIFY=true
