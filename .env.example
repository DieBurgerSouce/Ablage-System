# Ablage-System Environment Variables
# Copy this file to .env and update with your values

# Database
DB_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://ablage_admin:changeme@localhost:5433/ablage_system

# Redis
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false

# Security - JWT Authentication
# IMPORTANT: Generate a secure secret key for production:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Requirements
# Minimum 8 characters, must contain: uppercase, lowercase, digit, special char

# GPU
CUDA_VISIBLE_DEVICES=0

# Application
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=INFO
DEBUG=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_DOCUMENTS_PER_HOUR=10
DEFAULT_USER_DAILY_QUOTA=100

# Rate Limit Tiers
RATE_LIMIT_FREE_HOURLY=10
RATE_LIMIT_FREE_DAILY=50
RATE_LIMIT_PREMIUM_HOURLY=100
RATE_LIMIT_PREMIUM_DAILY=1000
RATE_LIMIT_ADMIN_HOURLY=10000

# Rate Limit Windows (in seconds)
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_REGISTER_ATTEMPTS=3
RATE_LIMIT_REGISTER_WINDOW=3600

# Rate Limit Whitelist (comma-separated IPs)
# RATE_LIMIT_WHITELIST=127.0.0.1,::1,10.0.0.1

# Monitoring (optional)
FLOWER_USER=admin
FLOWER_PASSWORD=admin
PGADMIN_EMAIL=admin@ablage-system.local
PGADMIN_PASSWORD=admin
