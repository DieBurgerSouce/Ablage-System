# .env.rag
# Environment Variablen fuer RAG Intelligence Layer
#
# Kopieren nach .env.rag und anpassen:
#   cp .env.rag.example .env.rag

# =========================================================================
# SERVICE URLS
# =========================================================================
EMBEDDING_SERVICE_URL=http://embedding-service:8080
RERANKER_SERVICE_URL=http://reranker-service:8080
OLLAMA_URL=http://ollama:11434

# =========================================================================
# MODEL CONFIGURATION
# =========================================================================
DEFAULT_EMBEDDING_MODEL=intfloat/multilingual-e5-large
DEFAULT_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
DEFAULT_LLM_REALTIME=qwen3:8b-q4_K_M
DEFAULT_LLM_ANALYSIS=qwen3:14b-q4_K_M

# =========================================================================
# RAG SETTINGS
# =========================================================================
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_SEARCH_LIMIT=20
RAG_SEARCH_THRESHOLD=0.7
RAG_RERANK_ENABLED=true
RAG_RERANK_TOP_K=10

# =========================================================================
# CUSTOMER CARDS
# =========================================================================
CUSTOMER_CARD_SYNC_ENABLED=true
CUSTOMER_CARD_SYNC_CRON="0 3 * * *"
CUSTOMER_CARD_SYNC_BATCH_SIZE=50

# =========================================================================
# PERFORMANCE
# =========================================================================
LLM_MAX_CONCURRENT_REQUESTS=4
EMBEDDING_BATCH_SIZE=32
SEARCH_CACHE_TTL=300

# =========================================================================
# OPTIONAL: HUGGINGFACE TOKEN (fuer private Modelle)
# =========================================================================
HF_TOKEN=
