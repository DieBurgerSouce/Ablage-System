# Dockerfile for Celery Worker with GPU Support
# Ablage-System OCR Multi-Agent Worker
# Priority: P1
# Created: 2024-11-25
# Updated: Multi-stage build to remove build tools from production image

# =============================================================================
# STAGE 1: BUILDER - Compile wheels and install dependencies
# =============================================================================

# Pin base image digest for reproducible builds
# Update digest via: docker manifest inspect nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04@sha256:309fb03c970e7938385a1c4c888a3b2f6dbb4639f8c316ff2d8b722ecf2b56f1 AS builder

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# Install Python + build tools (only needed for compilation)
RUN apt-get update && apt-get install -y \
    python3.11 \
    python3.11-dev \
    python3-pip \
    build-essential \
    gcc \
    g++ \
    libpoppler-cpp-dev \
    poppler-utils \
    tesseract-ocr \
    tesseract-ocr-deu \
    libtesseract-dev \
    ghostscript \
    libgl1-mesa-glx \
    libglib2.0-0 \
    wget \
    curl \
    git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip and install uv for fast dependency resolution
RUN python3.11 -m pip install --no-cache-dir --upgrade pip setuptools wheel uv

# Copy requirements files
COPY requirements.txt /app/requirements.txt
COPY requirements-dev.txt /app/requirements-dev.txt

# Install Python dependencies (uv is 10-100x faster than pip)
RUN uv pip install --system -r requirements.txt

# Install PyTorch with CUDA support (specific version for RTX 4080)
RUN uv pip install --system \
    torch==2.1.2+cu121 \
    torchvision==0.16.2+cu121 \
    torchaudio==2.1.2+cu121 \
    --index-url https://download.pytorch.org/whl/cu121

# Install transformers and additional ML libraries
RUN uv pip install --system \
    transformers>=4.35.0 \
    accelerate>=0.25.0 \
    bitsandbytes>=0.41.0 \
    sentencepiece>=0.1.99 \
    protobuf>=4.25.0

# =============================================================================
# STAGE 2: RUNTIME - Production image without build tools
# =============================================================================

FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04@sha256:309fb03c970e7938385a1c4c888a3b2f6dbb4639f8c316ff2d8b722ecf2b56f1

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# Install only runtime dependencies (NO build-essential, gcc, g++, git, wget)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3-pip \
    libpoppler-cpp-dev \
    poppler-utils \
    tesseract-ocr \
    tesseract-ocr-deu \
    libtesseract-dev \
    ghostscript \
    libgl1-mesa-glx \
    libglib2.0-0 \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy installed Python packages from builder
COPY --from=builder /usr/lib/python3/dist-packages /usr/lib/python3/dist-packages
COPY --from=builder /usr/local/lib/python3.11/dist-packages /usr/local/lib/python3.11/dist-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# =============================================================================
# APPLICATION CODE
# =============================================================================

COPY app/ /app/app/
COPY Skills/ /app/Skills/
COPY alembic/ /app/alembic/
COPY alembic.ini /app/alembic.ini

# Create necessary directories
RUN mkdir -p /app/logs /app/data /app/models /app/temp

# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================

# Python
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app

# CUDA
ENV CUDA_VISIBLE_DEVICES=0
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Celery
ENV CELERY_BROKER_URL=redis://redis:6379/1
ENV CELERY_RESULT_BACKEND=redis://redis:6379/2
# Application
ENV LOG_LEVEL=INFO
ENV WORKERS=1
ENV CONCURRENCY=1
ENV POOL=solo

# =============================================================================
# GPU OPTIMIZATION
# =============================================================================

# Set GPU memory fraction (prevent OOM)
ENV CUDA_MEM_FRACTION=0.85

# Enable TensorFloat-32 for performance on Ampere GPUs (RTX 4080)
ENV NVIDIA_TF32_OVERRIDE=1

# cuDNN optimization
ENV CUDNN_BENCHMARK=1

# =============================================================================
# HEALTH CHECK
# =============================================================================

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD celery -A app.workers.celery_app inspect ping || exit 1

# =============================================================================
# USER & PERMISSIONS
# =============================================================================

# Create non-root user for security
RUN useradd -m -u 1000 celery && \
    chown -R celery:celery /app

# Switch to non-root user
USER celery

# =============================================================================
# STARTUP
# =============================================================================

# Default command: GPU worker for OCR tasks
CMD ["celery", "-A", "app.workers.celery_app", "worker", \
     "--queues=ocr_gpu,ocr.deepseek,ocr.got_ocr,ocr.hybrid", \
     "--loglevel=info", \
     "--concurrency=1", \
     "--pool=solo", \
     "--hostname=gpu-worker@%h", \
     "--max-tasks-per-child=10", \
     "--task-events"]
