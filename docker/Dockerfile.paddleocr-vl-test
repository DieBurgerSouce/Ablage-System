RUN chmod +x /app/verify_gpu.sh

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV CUDA_VISIBLE_DEVICES=0

# Default command - verify GPU first, then run tests
CMD ["/bin/bash", "-c", "/app/verify_gpu.sh && python /app/test_paddleocr_vl_isolated.py"]

