# PaddleOCR-VL 0.9B Test Container
# Isolated test environment for PaddleOCR-VL 0.9B evaluation
# GPU required (CUDA 12.x)
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3.11 \
    python3.11-dev \
    python3-pip \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    libgomp1 \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create symlink for python
RUN ln -s /usr/bin/python3.11 /usr/bin/python

# Install Python dependencies for PaddleOCR-VL
# Note: PaddleOCR-VL 0.9B requires GPU support
RUN pip3 install --no-cache-dir --upgrade pip setuptools wheel

# Install PyTorch with CUDA 12.1 support
RUN pip3 install --no-cache-dir \
    torch==2.1.2 \
    torchvision==0.16.2 \
    --index-url https://download.pytorch.org/whl/cu121

# Install PaddlePaddle GPU (CUDA 12.6)
RUN pip3 install --no-cache-dir \
    paddlepaddle-gpu==3.2.1 \
    -i https://www.paddlepaddle.org.cn/packages/stable/cu126/

# Install PaddleOCR 3.3.2 (latest stable version)
# Note: PaddleOCR-VL 0.9B is not yet available (Dec 2025)
# Fix NumPy version for PyTorch compatibility
RUN pip3 install --no-cache-dir \
    "numpy<2.0" \
    paddleocr==3.3.2 \
    transformers>=4.45.0 \
    accelerate>=0.25.0 \
    safetensors>=0.6.2 \
    Pillow>=10.2.0 \
    qwen-vl-utils>=0.0.2 \
    opencv-python-headless>=4.8.0

# Install additional dependencies for document processing
RUN pip3 install --no-cache-dir \
    pypdfium2>=4.30.0 \
    pdf2image>=1.16.0

# Create directories
RUN mkdir -p /app/test_images /app/results /app/scripts

# Create test script for PaddleOCR-VL 0.9B
RUN cat > /app/test_paddleocr_vl_isolated.py << 'SCRIPT'
# -*- coding: utf-8 -*-
"""Isolated test script for PaddleOCR-VL 0.9B evaluation.

This script tests PaddleOCR-VL 0.9B in an isolated Docker environment
without affecting production code.
"""
import time
import os
import sys
import json
import warnings
from pathlib import Path
from typing import Dict, Any, Optional
import traceback

warnings.filterwarnings("ignore")

# Import PIL and other dependencies at module level
from PIL import Image
import numpy as np
import torch

# Test configuration
TEST_IMAGES_DIR = Path("/app/test_images")
RESULTS_DIR = Path("/app/results")
RESULTS_DIR.mkdir(exist_ok=True)

def get_vram_usage() -> Dict[str, float]:
    """Get current VRAM usage in GB."""
    try:
        import torch
        if torch.cuda.is_available():
            allocated = torch.cuda.memory_allocated(0) / 1024**3
            reserved = torch.cuda.memory_reserved(0) / 1024**3
            total = torch.cuda.get_device_properties(0).total_memory / 1024**3
            return {
                "allocated_gb": round(allocated, 2),
                "reserved_gb": round(reserved, 2),
                "total_gb": round(total, 2),
                "usage_percent": round((reserved / total) * 100, 1)
            }
    except Exception:
        pass
    return {"error": "VRAM info not available"}


def test_paddleocr_vl(image_path: str) -> Dict[str, Any]:
    """Test PaddleOCR-VL 0.9B on a single image.

    Args:
        image_path: Path to test image

    Returns:
        Dictionary with test results
    """
    result = {
        "backend": "paddleocr-vl-0.9b",
        "image_path": str(image_path),
        "success": False,
        "error": None,
        "processing_time_s": 0.0,
        "vram_before": {},
        "vram_after": {},
        "vram_peak_gb": 0.0,
        "text": "",
        "text_length": 0,
        "confidence": 0.0,
        "has_umlauts": False,
        "umlaut_count": 0
    }

    try:
        # VRAM monitoring (torch already imported at module level)
        # Get VRAM before
        result["vram_before"] = get_vram_usage()

        start_time = time.perf_counter()

        # Try to import PaddleOCR-VL
        # Note: PaddleOCR-VL 0.9B may not be available yet (Dec 2025)
        # Fallback to regular PaddleOCR for testing
        try:
            # Option 1: Direct import if available (future)
            from paddleocr_vl import PaddleOCRVL
            ocr = PaddleOCRVL(
                model_name='PaddleOCR-VL-0.9B',
                device='cuda',
                language='german'
            )
            print("✅ Using PaddleOCR-VL direct import")
        except ImportError:
            # Option 2: Regular PaddleOCR 3.3.2 (fallback for testing)
            # PaddleOCR 3.3.2 API changes:
            # - use_gpu: Removed (auto-detected)
            # - show_log: Removed (use logging)
            # - use_angle_cls: Removed (integrated into pipeline)
            from paddleocr import PaddleOCR
            ocr = PaddleOCR(
                lang='german'
                # Note: cls=True can be passed to .ocr() method for angle classification
                # Device (CPU/GPU) is automatically detected
            )
            print("⚠️  PaddleOCR-VL 0.9B not available, using regular PaddleOCR 3.3.2 for testing")

        # Load image (Image and np already imported at module level)
        img = Image.open(image_path).convert('RGB')
        img_np = np.array(img)

        # Process with PaddleOCR 3.3.2
        # Standard PaddleOCR API uses .ocr() method
        # Note: cls parameter removed in 3.3.2 (angle classification integrated)
        # Returns: [[[bbox], (text, confidence)], ...] or None
        if hasattr(ocr, 'ocr'):
            ocr_result = ocr.ocr(img_np)  # cls parameter removed in 3.3.2
        elif hasattr(ocr, 'process'):
            ocr_result = ocr.process(img_np)
        else:
            raise AttributeError("PaddleOCR object has neither 'ocr' nor 'process' method")

        # Extract text based on API format
        # PaddleOCR 3.3.2 returns dict format with structured data
        if ocr_result is None:
            text = ""
            confidence = 0.0
        elif isinstance(ocr_result, dict):
            # PaddleOCR 3.3.2 structured output format
            # Format: {'ocr_result': [[[bbox], (text, confidence)], ...], ...}
            text_lines = []
            confidences = []

            # Try to find OCR results in the dict
            if 'ocr_result' in ocr_result:
                ocr_data = ocr_result['ocr_result']
                if isinstance(ocr_data, list):
                    for line in ocr_data:
                        if isinstance(line, (list, tuple)) and len(line) >= 2:
                            text_data = line[1]
                            if isinstance(text_data, (list, tuple)) and len(text_data) >= 2:
                                text_lines.append(str(text_data[0]))
                                confidences.append(float(text_data[1]))

            # Alternative: check for 'pages' key
            if not text_lines and 'pages' in ocr_result:
                for page in ocr_result['pages']:
                    if isinstance(page, dict) and 'ocr_result' in page:
                        ocr_data = page['ocr_result']
                        if isinstance(ocr_data, list):
                            for line in ocr_data:
                                if isinstance(line, (list, tuple)) and len(line) >= 2:
                                    text_data = line[1]
                                    if isinstance(text_data, (list, tuple)) and len(text_data) >= 2:
                                        text_lines.append(str(text_data[0]))
                                        confidences.append(float(text_data[1]))

            text = '\n'.join(text_lines)
            confidence = sum(confidences) / len(confidences) if confidences else 0.0
        elif isinstance(ocr_result, list):
            # PaddleOCR 3.3.2 format: Can be nested
            # Format: [[[bbox], (text, confidence)], ...] or [[[[bbox], (text, conf)]], ...] for pages
            text_lines = []
            confidences = []

            # Handle nested structure (check if first element is a page)
            if ocr_result and len(ocr_result) > 0:
                first_item = ocr_result[0]
                # Check if it's a page (list of lines) or a line directly
                if isinstance(first_item, list) and len(first_item) > 0:
                    # Check if first element of first item is a bbox (list of 4 points)
                    if isinstance(first_item[0], list) and len(first_item[0]) >= 4:
                        # Single page format: [[[bbox], (text, conf)], ...]
                        for line in ocr_result:
                            if isinstance(line, (list, tuple)) and len(line) >= 2:
                                bbox = line[0]
                                text_data = line[1]
                                if isinstance(text_data, (list, tuple)) and len(text_data) >= 2:
                                    text_lines.append(str(text_data[0]))
                                    confidences.append(float(text_data[1]))
                    else:
                        # Multi-page format: [[[[bbox], (text, conf)], ...], ...]
                        for page in ocr_result:
                            if isinstance(page, list):
                                for line in page:
                                    if isinstance(line, (list, tuple)) and len(line) >= 2:
                                        text_data = line[1]
                                        if isinstance(text_data, (list, tuple)) and len(text_data) >= 2:
                                            text_lines.append(str(text_data[0]))
                                            confidences.append(float(text_data[1]))

            text = '\n'.join(text_lines)
            confidence = sum(confidences) / len(confidences) if confidences else 0.0
        else:
            text = str(ocr_result)
            confidence = 0.0

        processing_time = time.perf_counter() - start_time

        # Get VRAM after
        result["vram_after"] = get_vram_usage()
        result["vram_peak_gb"] = result["vram_after"].get("reserved_gb", 0.0)

        # Check for German umlauts
        umlauts = ['ä', 'ö', 'ü', 'ß', 'Ä', 'Ö', 'Ü']
        umlaut_count = sum(1 for char in text if char in umlauts)

        result.update({
            "success": True,
            "processing_time_s": round(processing_time, 2),
            "text": text,
            "text_length": len(text),
            "confidence": round(confidence, 3),
            "has_umlauts": umlaut_count > 0,
            "umlaut_count": umlaut_count
        })

        print(f"✅ Success: {processing_time:.2f}s, {len(text)} chars, {confidence:.1%} conf, {umlaut_count} umlauts")
        print(f"   VRAM: {result['vram_peak_gb']:.2f} GB")

    except Exception as e:
        result["error"] = str(e)
        result["vram_after"] = get_vram_usage()
        print(f"❌ Error: {e}")
        traceback.print_exc()

    return result


def main():
    """Main test function."""
    print("="*60)
    print("PADDLEOCR-VL 0.9B ISOLATED TEST")
    print("="*60)
    print(f"Test images directory: {TEST_IMAGES_DIR}")
    print(f"Results directory: {RESULTS_DIR}")
    print()

    # Check for test images
    image_files = list(TEST_IMAGES_DIR.glob("*.png")) + \
                  list(TEST_IMAGES_DIR.glob("*.jpg")) + \
                  list(TEST_IMAGES_DIR.glob("*.tif")) + \
                  list(TEST_IMAGES_DIR.glob("*.TIF"))

    if not image_files:
        print("⚠️  No test images found in /app/test_images")
        print("   Mount test images: docker run -v /path/to/images:/app/test_images ...")
        return

    print(f"Found {len(image_files)} test image(s)")
    print()

    # Test on first 3 images (basic functionality test)
    test_images = image_files[:3]
    results = []

    for i, image_path in enumerate(test_images, 1):
        print(f"[{i}/{len(test_images)}] Testing: {image_path.name}")
        result = test_paddleocr_vl(image_path)
        results.append(result)
        print()

    # Save results
    results_file = RESULTS_DIR / "paddleocr_vl_test_results.json"
    with open(results_file, "w", encoding="utf-8") as f:
        json.dump({
            "test_date": time.strftime("%Y-%m-%d %H:%M:%S"),
            "backend": "paddleocr-vl-0.9b",
            "test_images_count": len(test_images),
            "results": results,
            "summary": {
                "successful": sum(1 for r in results if r["success"]),
                "failed": sum(1 for r in results if not r["success"]),
                "avg_processing_time": sum(r["processing_time_s"] for r in results) / len(results) if results else 0,
                "avg_vram_gb": sum(r["vram_peak_gb"] for r in results) / len(results) if results else 0,
                "total_umlauts": sum(r["umlaut_count"] for r in results)
            }
        }, f, indent=2, ensure_ascii=False)

    print("="*60)
    print("TEST SUMMARY")
    print("="*60)
    successful = sum(1 for r in results if r["success"])
    print(f"Successful: {successful}/{len(results)}")
    if successful > 0:
        avg_time = sum(r["processing_time_s"] for r in results if r["success"]) / successful
        avg_vram = sum(r["vram_peak_gb"] for r in results if r["success"]) / successful
        total_umlauts = sum(r["umlaut_count"] for r in results if r["success"])
        print(f"Avg processing time: {avg_time:.2f}s")
        print(f"Avg VRAM usage: {avg_vram:.2f} GB")
        print(f"Total umlauts detected: {total_umlauts}")
    print(f"\nResults saved to: {results_file}")
    print("="*60)


if __name__ == "__main__":
    main()
SCRIPT

# Make script executable
RUN chmod +x /app/test_paddleocr_vl_isolated.py

# Create GPU verification script
RUN cat > /app/verify_gpu.sh << 'SCRIPT'
