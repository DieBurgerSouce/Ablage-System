# =============================================================================
# K3s Agent Configuration
# Generated by Ansible for Ablage-System OCR Infrastructure
# =============================================================================

# Server connection
server: "{{ k3s_server_url }}"
token: "{{ k3s_token }}"

# Data directory
data-dir: "{{ k3s_data_dir }}"

# Node name
node-name: "{{ inventory_hostname }}"

# Kubelet settings
kubelet-arg:
  - "system-reserved=cpu=250m,memory=512Mi"
  - "kube-reserved=cpu=250m,memory=512Mi"
  - "eviction-hard=memory.available<500Mi,nodefs.available<10%"
  - "max-pods=110"
{% if k3s_kubelet_extra_args is defined %}
{% for arg in k3s_kubelet_extra_args %}
  - "{{ arg }}"
{% endfor %}
{% endif %}

# Node labels
node-label:
{% for label in k3s_node_labels %}
  - "{{ label }}"
{% endfor %}

# Node taints
{% if k3s_node_taints | length > 0 %}
node-taint:
{% for taint in k3s_node_taints %}
  - "{{ taint }}"
{% endfor %}
{% endif %}
