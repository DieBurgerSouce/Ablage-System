# =============================================================================
# K3s Server Configuration
# Generated by Ansible for Ablage-System OCR Infrastructure
# =============================================================================

# Cluster settings
token: "{{ k3s_token }}"
cluster-cidr: "10.42.0.0/16"
service-cidr: "10.43.0.0/16"
cluster-dns: "10.43.0.10"

# TLS settings
tls-san:
  - "{{ k3s_api_server_host }}"
  - "{{ ansible_host }}"
  - "127.0.0.1"
  - "localhost"
{% if k3s_additional_sans is defined %}
{% for san in k3s_additional_sans %}
  - "{{ san }}"
{% endfor %}
{% endif %}

# Networking
flannel-backend: "vxlan"
{% if k3s_disable_network_policy | default(false) %}
disable-network-policy: true
{% endif %}

# Disable default components (we use our own)
disable:
  - traefik
  - servicelb
{% if k3s_disable_local_storage | default(false) %}
  - local-storage
{% endif %}

# Kubeconfig permissions
write-kubeconfig-mode: "0644"

# Data directory
data-dir: "{{ k3s_data_dir }}"

# Kubelet settings
kubelet-arg:
  - "system-reserved=cpu=500m,memory=1Gi"
  - "kube-reserved=cpu=500m,memory=1Gi"
  - "eviction-hard=memory.available<500Mi,nodefs.available<10%"
  - "max-pods=110"
{% if k3s_kubelet_extra_args is defined %}
{% for arg in k3s_kubelet_extra_args %}
  - "{{ arg }}"
{% endfor %}
{% endif %}

# Kube-apiserver settings
kube-apiserver-arg:
  - "enable-admission-plugins=NodeRestriction,PodSecurityPolicy"
  - "audit-log-path=/var/log/kubernetes/audit.log"
  - "audit-log-maxage=30"
  - "audit-log-maxbackup=10"
  - "audit-log-maxsize=100"
{% if k3s_apiserver_extra_args is defined %}
{% for arg in k3s_apiserver_extra_args %}
  - "{{ arg }}"
{% endfor %}
{% endif %}

# Kube-controller-manager settings
kube-controller-manager-arg:
  - "terminated-pod-gc-threshold=100"
{% if k3s_controller_extra_args is defined %}
{% for arg in k3s_controller_extra_args %}
  - "{{ arg }}"
{% endfor %}
{% endif %}

# Etcd settings
{% if k3s_etcd_enabled %}
cluster-init: true
etcd-expose-metrics: true
{% endif %}

# Node labels
node-label:
{% for label in k3s_node_labels %}
  - "{{ label }}"
{% endfor %}

# Node taints (for control-plane only nodes)
{% if k3s_control_plane_only | default(false) %}
node-taint:
  - "node-role.kubernetes.io/control-plane:NoSchedule"
{% endif %}
