# Ablage-System Docker Compose Override
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Environment: {{ env_name }}
version: '3.8'

services:
  postgres:
    environment:
      POSTGRES_MAX_CONNECTIONS: {{ postgres_max_connections | default(100) }}
      POSTGRES_SHARED_BUFFERS: {{ postgres_shared_buffers | default('256MB') }}

  redis:
    command: redis-server --appendonly yes --maxmemory {{ redis_maxmemory | default('2gb') }} --maxmemory-policy allkeys-lru

  backend:
    environment:
      LOG_LEVEL: {{ log_level | default('INFO') }}
      DEBUG: "{{ debug_mode | default(false) | lower }}"
{% if env_name == 'development' %}
    volumes:
      - ./app:/app/app:rw
{% endif %}

  worker:
    environment:
      LOG_LEVEL: {{ log_level | default('INFO') }}

{% if env_name == 'production' %}
  # Production-specific configurations
  prometheus:
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--storage.tsdb.retention.time={{ prometheus_retention_days | default(30) }}d'
      - '--web.console.libraries=/usr/share/prometheus/console_libraries'
      - '--web.console.templates=/usr/share/prometheus/consoles'
      - '--web.enable-lifecycle'
{% endif %}
