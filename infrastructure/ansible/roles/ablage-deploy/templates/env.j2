# Ablage-System Environment Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Environment: {{ env_name }}
# DO NOT EDIT MANUALLY - Changes will be overwritten

# ============================================================
# DATABASE
# ============================================================
DB_PASSWORD={{ vault_db_password }}
DATABASE_URL=postgresql+asyncpg://ablage_admin:{{ vault_db_password }}@postgres:5432/ablage_system

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================================
# MINIO (S3-Compatible Storage)
# ============================================================
MINIO_ROOT_USER={{ vault_minio_root_user }}
MINIO_ROOT_PASSWORD={{ vault_minio_root_password }}
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY={{ vault_minio_root_user }}
MINIO_SECRET_KEY={{ vault_minio_root_password }}
MINIO_SECURE=false

# ============================================================
# SECURITY - JWT Authentication
# ============================================================
SECRET_KEY={{ vault_secret_key }}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES={{ access_token_expire_minutes | default(15) }}
REFRESH_TOKEN_EXPIRE_DAYS={{ refresh_token_expire_days | default(7) }}

# ============================================================
# GPU
# ============================================================
CUDA_VISIBLE_DEVICES={{ cuda_visible_devices | default('0') }}

# ============================================================
# APPLICATION
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD={{ api_reload | default(false) | lower }}
LOG_LEVEL={{ log_level | default('INFO') }}
DEBUG={{ debug_mode | default(false) | lower }}

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED={{ rate_limit_enabled | default(true) | lower }}
RATE_LIMIT_REQUESTS_PER_MINUTE={{ rate_limit_requests_per_minute | default(100) }}
RATE_LIMIT_DOCUMENTS_PER_HOUR={{ rate_limit_documents_per_hour | default(10) }}
DEFAULT_USER_DAILY_QUOTA={{ default_user_daily_quota | default(100) }}

# Rate Limit Tiers
RATE_LIMIT_FREE_HOURLY=10
RATE_LIMIT_FREE_DAILY=50
RATE_LIMIT_PREMIUM_HOURLY=100
RATE_LIMIT_PREMIUM_DAILY=1000
RATE_LIMIT_ADMIN_HOURLY=10000

# Rate Limit Windows (in seconds)
RATE_LIMIT_LOGIN_ATTEMPTS={{ rate_limit_login_attempts | default(5) }}
RATE_LIMIT_LOGIN_WINDOW={{ rate_limit_login_window | default(900) }}
RATE_LIMIT_REGISTER_ATTEMPTS=3
RATE_LIMIT_REGISTER_WINDOW=3600

# ============================================================
# MONITORING
# ============================================================
GRAFANA_USER={{ grafana_user | default('admin') }}
GRAFANA_PASSWORD={{ vault_grafana_password }}

{% if vault_flower_user is defined %}
# Celery Flower
FLOWER_USER={{ vault_flower_user }}
FLOWER_PASSWORD={{ vault_flower_password }}
{% endif %}

# ============================================================
# ENVIRONMENT IDENTIFIER
# ============================================================
ENVIRONMENT={{ env_name }}
DOMAIN_NAME={{ domain_name }}
