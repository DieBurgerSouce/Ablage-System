#!/bin/bash
# Ablage-System Alert Sending Script
# Auto-generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

REPORT_FILE="$1"
ALERT_EMAIL="{{ health_check_alert_email }}"
ALERT_WEBHOOK="{{ health_check_alert_webhook }}"
ALERT_LOG="/var/log/ablage/alerts/alerts.log"
HOSTNAME=$(hostname)

log_alert() {
    echo "[$(date -Iseconds)] $1" >> "${ALERT_LOG}"
}

# Send email alert
send_email_alert() {
    if [[ -z "${ALERT_EMAIL}" ]]; then
        return
    fi

    local subject="[ABLAGE-ALERT] Gesundheitsprüfung fehlgeschlagen auf ${HOSTNAME}"
    local body="Die Ablage-System Gesundheitsprüfung hat Probleme festgestellt.

Hostname: ${HOSTNAME}
Zeitpunkt: $(date)

Bericht:
$(cat "${REPORT_FILE}")

---
Diese Nachricht wurde automatisch generiert."

    if command -v mail &> /dev/null; then
        echo "${body}" | mail -s "${subject}" "${ALERT_EMAIL}"
        log_alert "E-Mail-Benachrichtigung gesendet an ${ALERT_EMAIL}"
    elif command -v msmtp &> /dev/null; then
        echo -e "Subject: ${subject}\n\n${body}" | msmtp "${ALERT_EMAIL}"
        log_alert "E-Mail-Benachrichtigung gesendet an ${ALERT_EMAIL}"
    else
        log_alert "Kein E-Mail-Client verfügbar"
    fi
}

# Send webhook alert
send_webhook_alert() {
    if [[ -z "${ALERT_WEBHOOK}" ]]; then
        return
    fi

    local payload=$(cat <<EOF
{
    "hostname": "${HOSTNAME}",
    "timestamp": "$(date -Iseconds)",
    "status": "unhealthy",
    "message": "Ablage-System Gesundheitsprüfung fehlgeschlagen",
    "report": $(cat "${REPORT_FILE}")
}
EOF
)

    response=$(curl -s -o /dev/null -w "%{http_code}" -X POST \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        "${ALERT_WEBHOOK}" || echo "000")

    if [[ "${response}" == "200" || "${response}" == "204" ]]; then
        log_alert "Webhook-Benachrichtigung gesendet"
    else
        log_alert "Webhook-Benachrichtigung fehlgeschlagen: HTTP ${response}"
    fi
}

# Main
if [[ ! -f "${REPORT_FILE}" ]]; then
    echo "Berichtsdatei nicht gefunden: ${REPORT_FILE}"
    exit 1
fi

mkdir -p "$(dirname "${ALERT_LOG}")"

log_alert "Beginne Benachrichtigungsversand für ${REPORT_FILE}"

send_email_alert
send_webhook_alert

log_alert "Benachrichtigungsversand abgeschlossen"
