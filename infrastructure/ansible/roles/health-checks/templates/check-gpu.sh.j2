#!/bin/bash
# Ablage-System GPU Health Check
# Auto-generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

GPU_MEMORY_THRESHOLD={{ health_check_gpu_memory_threshold }}
GPU_TEMP_THRESHOLD={{ health_check_gpu_temperature_threshold }}

ISSUES=()

# Check if nvidia-smi is available
if ! command -v nvidia-smi &> /dev/null; then
    echo "nvidia-smi nicht gefunden - GPU-Prüfung übersprungen"
    exit 0
fi

# Get GPU stats
gpu_stats=$(nvidia-smi --query-gpu=memory.used,memory.total,temperature.gpu,gpu_name --format=csv,noheader,nounits 2>/dev/null)

if [[ -z "${gpu_stats}" ]]; then
    echo "Keine GPU-Daten verfügbar"
    exit 1
fi

while IFS=',' read -r mem_used mem_total temperature gpu_name; do
    # Trim whitespace
    mem_used=$(echo "${mem_used}" | xargs)
    mem_total=$(echo "${mem_total}" | xargs)
    temperature=$(echo "${temperature}" | xargs)
    gpu_name=$(echo "${gpu_name}" | xargs)

    # Calculate memory percentage
    if [[ ${mem_total} -gt 0 ]]; then
        mem_percent=$((mem_used * 100 / mem_total))
    else
        mem_percent=0
    fi

    # Check memory threshold
    if [[ ${mem_percent} -gt ${GPU_MEMORY_THRESHOLD} ]]; then
        ISSUES+=("GPU-Speicher:${mem_percent}%>${GPU_MEMORY_THRESHOLD}%")
    fi

    # Check temperature threshold
    if [[ ${temperature} -gt ${GPU_TEMP_THRESHOLD} ]]; then
        ISSUES+=("GPU-Temperatur:${temperature}°C>${GPU_TEMP_THRESHOLD}°C")
    fi

done <<< "${gpu_stats}"

if [[ ${#ISSUES[@]} -gt 0 ]]; then
    echo "GPU-Probleme: ${ISSUES[*]}"
    exit 1
fi

# Get current stats for success message
current_mem_used=$(nvidia-smi --query-gpu=memory.used --format=csv,noheader,nounits | head -1 | xargs)
current_mem_total=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits | head -1 | xargs)
current_temp=$(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits | head -1 | xargs)
mem_percent=$((current_mem_used * 100 / current_mem_total))

echo "GPU OK (Speicher:${mem_percent}%, Temperatur:${current_temp}°C)"
exit 0
