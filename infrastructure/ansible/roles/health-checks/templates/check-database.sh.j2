#!/bin/bash
# Ablage-System Database Health Check
# Auto-generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

INSTALL_DIR="{{ ablage_install_dir }}"
ISSUES=()

cd "${INSTALL_DIR}"

# Check PostgreSQL
pg_status=$(docker compose exec -T postgres pg_isready -U ablage_admin -d ablage_system 2>&1)
if [[ $? -ne 0 ]]; then
    ISSUES+=("PostgreSQL:nicht bereit")
fi

# Check Redis
redis_status=$(docker compose exec -T redis redis-cli ping 2>&1)
if [[ "${redis_status}" != "PONG" ]]; then
    ISSUES+=("Redis:nicht erreichbar")
fi

# Check MinIO
minio_status=$(docker compose exec -T minio mc admin info local 2>&1 || echo "error")
if [[ "${minio_status}" == *"error"* ]]; then
    ISSUES+=("MinIO:nicht verfügbar")
fi

# Check PostgreSQL connections
pg_connections=$(docker compose exec -T postgres psql -U ablage_admin -d ablage_system -t -c "SELECT count(*) FROM pg_stat_activity;" 2>/dev/null | xargs || echo "0")
pg_max_connections=$(docker compose exec -T postgres psql -U ablage_admin -d ablage_system -t -c "SHOW max_connections;" 2>/dev/null | xargs || echo "100")

if [[ -n "${pg_connections}" && -n "${pg_max_connections}" ]]; then
    connection_percent=$((pg_connections * 100 / pg_max_connections))
    if [[ ${connection_percent} -gt 80 ]]; then
        ISSUES+=("PostgreSQL-Verbindungen:${connection_percent}%>80%")
    fi
fi

# Check Redis memory
redis_used_memory=$(docker compose exec -T redis redis-cli INFO memory 2>/dev/null | grep used_memory_human | cut -d':' -f2 | tr -d '\r' || echo "0")

if [[ ${#ISSUES[@]} -gt 0 ]]; then
    echo "Datenbank-Probleme: ${ISSUES[*]}"
    exit 1
fi

echo "Datenbanken OK (PostgreSQL bereit, Redis: ${redis_used_memory})"
exit 0
