# Ablage-System Alert Configuration
# Auto-generated by Ansible - DO NOT EDIT MANUALLY
---
alerting:
  enabled: {{ health_check_alert_enabled | lower }}

  email:
    enabled: {{ (health_check_alert_email | length > 0) | lower }}
    recipients:
      - {{ health_check_alert_email }}

  webhook:
    enabled: {{ (health_check_alert_webhook | length > 0) | lower }}
{% if health_check_alert_webhook | length > 0 %}
    url: {{ health_check_alert_webhook }}
{% endif %}

  thresholds:
    cpu_percent: {{ health_check_cpu_threshold }}
    memory_percent: {{ health_check_memory_threshold }}
    disk_percent: {{ health_check_disk_threshold }}
    gpu_memory_percent: {{ health_check_gpu_memory_threshold }}
    gpu_temperature_celsius: {{ health_check_gpu_temperature_threshold }}
