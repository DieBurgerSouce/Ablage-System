#!/bin/bash
# Ablage-System Container Health Check
# Auto-generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

INSTALL_DIR="{{ ablage_install_dir }}"
CONTAINERS=({% for container in health_check_containers %}"{{ container }}" {% endfor %})
FAILED_CONTAINERS=()

cd "${INSTALL_DIR}"

for container in "${CONTAINERS[@]}"; do
    # Check if container is running
    status=$(docker compose ps --format json "${container}" 2>/dev/null | jq -r '.State' 2>/dev/null || echo "not_found")

    if [[ "${status}" != "running" ]]; then
        FAILED_CONTAINERS+=("${container}:${status}")
    fi
done

if [[ ${#FAILED_CONTAINERS[@]} -gt 0 ]]; then
    echo "Fehlerhafte Container: ${FAILED_CONTAINERS[*]}"
    exit 1
fi

echo "Alle Container laufen"
exit 0
