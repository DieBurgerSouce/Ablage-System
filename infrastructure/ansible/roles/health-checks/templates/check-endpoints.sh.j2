#!/bin/bash
# Ablage-System Endpoint Health Check
# Auto-generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

FAILED_ENDPOINTS=()

{% for endpoint in health_check_endpoints %}
# Check {{ endpoint.name }}
response=$(curl -s -o /dev/null -w "%{http_code}" --max-time {{ endpoint.timeout }} "{{ endpoint.url }}" 2>/dev/null || echo "000")
if [[ "${response}" != "{{ endpoint.expected_status }}" ]]; then
    FAILED_ENDPOINTS+=("{{ endpoint.name }}:HTTP${response}")
fi

{% endfor %}

if [[ ${#FAILED_ENDPOINTS[@]} -gt 0 ]]; then
    echo "Fehlerhafte Endpunkte: ${FAILED_ENDPOINTS[*]}"
    exit 1
fi

echo "Alle Endpunkte erreichbar"
exit 0
