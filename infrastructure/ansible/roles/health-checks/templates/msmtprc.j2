# Ablage-System MSMTP Configuration
# Auto-generated by Ansible - DO NOT EDIT MANUALLY

# Default settings
defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        /var/log/msmtp.log

# SMTP account configuration
account        ablage
host           {{ vault_smtp_server | default('smtp.example.com') }}
port           {{ vault_smtp_port | default(587) }}
from           {{ vault_smtp_from | default('ablage@example.com') }}
user           {{ vault_smtp_user | default('') }}
password       {{ vault_smtp_password | default('') }}

# Set default account
account default : ablage
