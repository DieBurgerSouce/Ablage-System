#!/bin/bash
# Ablage-System Resource Health Check
# Auto-generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

CPU_THRESHOLD={{ health_check_cpu_threshold }}
MEMORY_THRESHOLD={{ health_check_memory_threshold }}
DISK_THRESHOLD={{ health_check_disk_threshold }}

ISSUES=()

# Check CPU usage
cpu_usage=$(top -bn1 | grep "Cpu(s)" | awk '{print 100 - $8}' | cut -d'.' -f1)
if [[ ${cpu_usage} -gt ${CPU_THRESHOLD} ]]; then
    ISSUES+=("CPU:${cpu_usage}%>${CPU_THRESHOLD}%")
fi

# Check Memory usage
memory_usage=$(free | grep Mem | awk '{printf "%.0f", $3/$2 * 100}')
if [[ ${memory_usage} -gt ${MEMORY_THRESHOLD} ]]; then
    ISSUES+=("Speicher:${memory_usage}%>${MEMORY_THRESHOLD}%")
fi

# Check Disk usage
disk_usage=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
if [[ ${disk_usage} -gt ${DISK_THRESHOLD} ]]; then
    ISSUES+=("Festplatte:${disk_usage}%>${DISK_THRESHOLD}%")
fi

# Check data partition if separate
if mountpoint -q "{{ ablage_data_dir }}"; then
    data_disk_usage=$(df "{{ ablage_data_dir }}" | tail -1 | awk '{print $5}' | sed 's/%//')
    if [[ ${data_disk_usage} -gt ${DISK_THRESHOLD} ]]; then
        ISSUES+=("Daten-Partition:${data_disk_usage}%>${DISK_THRESHOLD}%")
    fi
fi

if [[ ${#ISSUES[@]} -gt 0 ]]; then
    echo "Ressourcen-Probleme: ${ISSUES[*]}"
    exit 1
fi

echo "Ressourcen OK (CPU:${cpu_usage}%, Speicher:${memory_usage}%, Festplatte:${disk_usage}%)"
exit 0
