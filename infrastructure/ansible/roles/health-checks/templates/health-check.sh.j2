#!/bin/bash
# Ablage-System Main Health Check Script
# Auto-generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

# Configuration
REPORT_DIR="{{ health_check_report_dir }}"
SCRIPTS_DIR="/usr/local/bin/ablage-health"
ALERT_ENABLED="{{ health_check_alert_enabled | lower }}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
REPORT_FILE="${REPORT_DIR}/health_${TIMESTAMP}.json"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Initialize report
declare -A RESULTS
OVERALL_STATUS="healthy"
ERRORS=()

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Run a check and capture result
run_check() {
    local check_name=$1
    local check_script=$2

    log_info "Ausführung: ${check_name}..."

    if [[ -x "${check_script}" ]]; then
        if result=$("${check_script}" 2>&1); then
            RESULTS["${check_name}"]="OK"
            log_info "${check_name}: OK"
        else
            RESULTS["${check_name}"]="FAILED"
            OVERALL_STATUS="unhealthy"
            ERRORS+=("${check_name}: ${result}")
            log_error "${check_name}: FEHLGESCHLAGEN"
        fi
    else
        RESULTS["${check_name}"]="SKIPPED"
        log_warn "${check_name}: Script nicht gefunden, übersprungen"
    fi
}

# Generate JSON report
generate_report() {
    local report="{
  \"timestamp\": \"$(date -Iseconds)\",
  \"hostname\": \"$(hostname)\",
  \"status\": \"${OVERALL_STATUS}\",
  \"checks\": {"

    local first=true
    for key in "${!RESULTS[@]}"; do
        if [[ "$first" == true ]]; then
            first=false
        else
            report+=","
        fi
        report+="
    \"${key}\": \"${RESULTS[$key]}\""
    done

    report+="
  },
  \"errors\": ["

    first=true
    for error in "${ERRORS[@]}"; do
        if [[ "$first" == true ]]; then
            first=false
        else
            report+=","
        fi
        report+="
    \"${error}\""
    done

    report+="
  ]
}"

    echo "$report" > "${REPORT_FILE}"
    log_info "Bericht gespeichert: ${REPORT_FILE}"
}

# Send alerts if needed
send_alerts() {
    if [[ "${OVERALL_STATUS}" == "unhealthy" && "${ALERT_ENABLED}" == "true" ]]; then
        log_warn "System ist nicht gesund, sende Benachrichtigung..."
        if [[ -x "${SCRIPTS_DIR}/send-alert.sh" ]]; then
            "${SCRIPTS_DIR}/send-alert.sh" "${REPORT_FILE}"
        fi
    fi
}

main() {
    log_info "=== Ablage-System Gesundheitsprüfung gestartet ==="
    log_info "Zeitstempel: $(date)"

    # Ensure report directory exists
    mkdir -p "${REPORT_DIR}"

    # Run all checks
    run_check "containers" "${SCRIPTS_DIR}/check-containers.sh"
    run_check "endpoints" "${SCRIPTS_DIR}/check-endpoints.sh"
    run_check "resources" "${SCRIPTS_DIR}/check-resources.sh"
    run_check "database" "${SCRIPTS_DIR}/check-database.sh"

{% if nvidia_driver_enabled | default(true) | bool %}
    run_check "gpu" "${SCRIPTS_DIR}/check-gpu.sh"
{% endif %}

    # Generate report
    generate_report

    # Send alerts if needed
    send_alerts

    # Summary
    echo ""
    log_info "=== Zusammenfassung ==="
    if [[ "${OVERALL_STATUS}" == "healthy" ]]; then
        log_info "Gesamtstatus: ${GREEN}GESUND${NC}"
    else
        log_error "Gesamtstatus: ${RED}NICHT GESUND${NC}"
        echo ""
        log_error "Fehler:"
        for error in "${ERRORS[@]}"; do
            echo "  - ${error}"
        done
    fi

    # Exit with appropriate code
    if [[ "${OVERALL_STATUS}" == "healthy" ]]; then
        exit 0
    else
        exit 1
    fi
}

main "$@"
