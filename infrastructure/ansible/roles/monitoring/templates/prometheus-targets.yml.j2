# Ablage-System Prometheus Targets Configuration
# Auto-generated by Ansible - DO NOT EDIT MANUALLY
---
# Node Exporter targets
- targets:
    - "{{ inventory_hostname }}:{{ node_exporter_port }}"
  labels:
    job: node
    env: "{{ env_name | default('development') }}"
    instance: "{{ inventory_hostname }}"

{% if nvidia_exporter_enabled | bool %}
# NVIDIA GPU Exporter targets
- targets:
    - "{{ inventory_hostname }}:{{ nvidia_exporter_port }}"
  labels:
    job: nvidia_gpu
    env: "{{ env_name | default('development') }}"
    instance: "{{ inventory_hostname }}"
{% endif %}

# Ablage-System Backend API
- targets:
    - "{{ inventory_hostname }}:{{ ablage_backend_port | default(8000) }}"
  labels:
    job: ablage_api
    env: "{{ env_name | default('development') }}"
    instance: "{{ inventory_hostname }}"

# Redis
- targets:
    - "{{ inventory_hostname }}:{{ redis_exporter_port | default(9121) }}"
  labels:
    job: redis
    env: "{{ env_name | default('development') }}"
    instance: "{{ inventory_hostname }}"

# PostgreSQL
- targets:
    - "{{ inventory_hostname }}:{{ postgres_exporter_port | default(9187) }}"
  labels:
    job: postgres
    env: "{{ env_name | default('development') }}"
    instance: "{{ inventory_hostname }}"
