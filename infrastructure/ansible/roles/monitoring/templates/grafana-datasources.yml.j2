# Ablage-System Grafana Datasources Configuration
# Auto-generated by Ansible - DO NOT EDIT MANUALLY
apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: http://prometheus:9090
    isDefault: true
    editable: false
    jsonData:
      timeInterval: "15s"
      httpMethod: POST

  - name: Loki
    type: loki
    access: proxy
    url: http://loki:3100
    editable: false
    jsonData:
      maxLines: 1000

  - name: PostgreSQL
    type: postgres
    url: postgres:5432
    database: ablage_system
    user: {{ vault_db_user | default('ablage_readonly') }}
    secureJsonData:
      password: {{ vault_db_readonly_password | default('') }}
    jsonData:
      sslmode: disable
      maxOpenConns: 5
      maxIdleConns: 2
    editable: false
