# Ablage-System Prometheus Alert Rules
# Auto-generated by Ansible - DO NOT EDIT MANUALLY
groups:
  - name: ablage_system_alerts
    rules:
      # System Alerts
      - alert: HighCPUUsage
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > {{ alert_cpu_threshold }}
        for: 5m
        labels:
          severity: warning
          service: system
        annotations:
          summary: "Hohe CPU-Auslastung auf {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "CPU-Auslastung liegt bei {{ '{{' }} $value | printf \"%.1f\" {{ '}}' }}% (Schwellwert: {{ alert_cpu_threshold }}%)"

      - alert: HighMemoryUsage
        expr: (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100 > {{ alert_memory_threshold }}
        for: 5m
        labels:
          severity: warning
          service: system
        annotations:
          summary: "Hohe Speicherauslastung auf {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "Speicherauslastung liegt bei {{ '{{' }} $value | printf \"%.1f\" {{ '}}' }}% (Schwellwert: {{ alert_memory_threshold }}%)"

      - alert: HighDiskUsage
        expr: (1 - (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"})) * 100 > {{ alert_disk_threshold }}
        for: 10m
        labels:
          severity: warning
          service: system
        annotations:
          summary: "Hohe Festplattenauslastung auf {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "Festplattenauslastung liegt bei {{ '{{' }} $value | printf \"%.1f\" {{ '}}' }}% (Schwellwert: {{ alert_disk_threshold }}%)"

      - alert: InstanceDown
        expr: up == 0
        for: 2m
        labels:
          severity: critical
          service: system
        annotations:
          summary: "Instanz {{ '{{' }} $labels.instance {{ '}}' }} nicht erreichbar"
          description: "{{ '{{' }} $labels.job {{ '}}' }} auf {{ '{{' }} $labels.instance {{ '}}' }} ist seit 2 Minuten nicht erreichbar."

      # GPU Alerts
      - alert: GPUHighMemoryUsage
        expr: nvidia_gpu_memory_used_bytes / nvidia_gpu_memory_total_bytes * 100 > {{ alert_gpu_memory_threshold }}
        for: 5m
        labels:
          severity: warning
          service: gpu
        annotations:
          summary: "Hohe GPU-Speicherauslastung auf {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "GPU-Speicher bei {{ '{{' }} $value | printf \"%.1f\" {{ '}}' }}% (Schwellwert: {{ alert_gpu_memory_threshold }}%)"

      - alert: GPUHighTemperature
        expr: nvidia_gpu_temperature_celsius > {{ alert_gpu_temperature_threshold }}
        for: 5m
        labels:
          severity: warning
          service: gpu
        annotations:
          summary: "Hohe GPU-Temperatur auf {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "GPU-Temperatur bei {{ '{{' }} $value {{ '}}' }}°C (Schwellwert: {{ alert_gpu_temperature_threshold }}°C)"

      - alert: GPUNotAvailable
        expr: absent(nvidia_gpu_info)
        for: 5m
        labels:
          severity: critical
          service: gpu
        annotations:
          summary: "GPU nicht verfügbar auf {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "NVIDIA GPU Metriken sind nicht verfügbar. GPU möglicherweise ausgefallen oder Treiber nicht geladen."

      # Application Alerts
      - alert: AblageAPIHighLatency
        expr: histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job="ablage_api"}[5m])) > 2
        for: 5m
        labels:
          severity: warning
          service: ablage_api
        annotations:
          summary: "Hohe API-Latenz bei Ablage-System"
          description: "95. Perzentil der API-Latenz liegt bei {{ '{{' }} $value | printf \"%.2f\" {{ '}}' }}s"

      - alert: AblageAPIHighErrorRate
        expr: rate(http_request_total{job="ablage_api", status=~"5.."}[5m]) / rate(http_request_total{job="ablage_api"}[5m]) * 100 > 5
        for: 5m
        labels:
          severity: critical
          service: ablage_api
        annotations:
          summary: "Hohe Fehlerrate bei Ablage-System API"
          description: "Fehlerrate liegt bei {{ '{{' }} $value | printf \"%.1f\" {{ '}}' }}%"

      - alert: OCRProcessingBacklog
        expr: celery_queue_length{queue="ocr"} > 100
        for: 15m
        labels:
          severity: warning
          service: ocr
        annotations:
          summary: "OCR-Verarbeitungsstau"
          description: "{{ '{{' }} $value {{ '}}' }} Dokumente in der OCR-Warteschlange"

      - alert: OCRProcessingFailed
        expr: increase(ocr_processing_failed_total[1h]) > 10
        for: 5m
        labels:
          severity: warning
          service: ocr
        annotations:
          summary: "OCR-Verarbeitungsfehler häufen sich"
          description: "{{ '{{' }} $value {{ '}}' }} OCR-Fehler in der letzten Stunde"

      # Database Alerts
      - alert: PostgreSQLDown
        expr: pg_up == 0
        for: 2m
        labels:
          severity: critical
          service: postgres
        annotations:
          summary: "PostgreSQL nicht erreichbar"
          description: "PostgreSQL-Datenbank auf {{ '{{' }} $labels.instance {{ '}}' }} ist nicht erreichbar."

      - alert: PostgreSQLHighConnections
        expr: sum by (instance) (pg_stat_activity_count) / pg_settings_max_connections * 100 > 80
        for: 5m
        labels:
          severity: warning
          service: postgres
        annotations:
          summary: "Hohe PostgreSQL-Verbindungsauslastung"
          description: "{{ '{{' }} $value | printf \"%.1f\" {{ '}}' }}% der maximalen Verbindungen in Verwendung"

      # Redis Alerts
      - alert: RedisDown
        expr: redis_up == 0
        for: 2m
        labels:
          severity: critical
          service: redis
        annotations:
          summary: "Redis nicht erreichbar"
          description: "Redis auf {{ '{{' }} $labels.instance {{ '}}' }} ist nicht erreichbar."

      - alert: RedisHighMemory
        expr: redis_memory_used_bytes / redis_memory_max_bytes * 100 > 80
        for: 5m
        labels:
          severity: warning
          service: redis
        annotations:
          summary: "Hohe Redis-Speicherauslastung"
          description: "Redis-Speicher bei {{ '{{' }} $value | printf \"%.1f\" {{ '}}' }}%"

      # Backup Alerts
      - alert: BackupFailed
        expr: time() - backup_last_success_timestamp > 172800  # 48 hours
        for: 1h
        labels:
          severity: critical
          service: backup
        annotations:
          summary: "Backup fehlgeschlagen"
          description: "Letztes erfolgreiches Backup ist älter als 48 Stunden"
