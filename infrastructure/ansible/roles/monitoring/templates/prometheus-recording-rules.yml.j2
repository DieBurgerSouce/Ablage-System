# Ablage-System Prometheus Recording Rules
# Auto-generated by Ansible - DO NOT EDIT MANUALLY
groups:
  - name: ablage_recording_rules
    interval: 30s
    rules:
      # CPU usage
      - record: instance:cpu_usage:percent
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)

      # Memory usage
      - record: instance:memory_usage:percent
        expr: (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100

      # Disk usage
      - record: instance:disk_usage:percent
        expr: (1 - (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"})) * 100

      # GPU memory usage
      - record: instance:gpu_memory_usage:percent
        expr: nvidia_gpu_memory_used_bytes / nvidia_gpu_memory_total_bytes * 100

      # GPU utilization
      - record: instance:gpu_utilization:percent
        expr: nvidia_gpu_duty_cycle

      # API request rate
      - record: job:http_requests:rate5m
        expr: sum by(job) (rate(http_request_total[5m]))

      # API error rate
      - record: job:http_errors:rate5m
        expr: sum by(job) (rate(http_request_total{status=~"5.."}[5m]))

      # API latency 95th percentile
      - record: job:http_latency:p95
        expr: histogram_quantile(0.95, sum by(job, le) (rate(http_request_duration_seconds_bucket[5m])))

      # OCR processing rate
      - record: job:ocr_processing:rate5m
        expr: sum by(backend) (rate(ocr_processing_total[5m]))

      # OCR average duration
      - record: job:ocr_duration:avg5m
        expr: rate(ocr_processing_duration_seconds_sum[5m]) / rate(ocr_processing_duration_seconds_count[5m])

      # OCR success rate
      - record: job:ocr_success_rate:5m
        expr: sum(rate(ocr_processing_success_total[5m])) / sum(rate(ocr_processing_total[5m])) * 100

      # Document processing throughput
      - record: job:document_throughput:rate1h
        expr: sum(increase(document_processed_total[1h]))

      # Celery queue length
      - record: job:celery_queue_length:current
        expr: celery_queue_length

      # PostgreSQL connections
      - record: job:pg_connections:current
        expr: sum by(instance) (pg_stat_activity_count)

      # Redis memory usage
      - record: job:redis_memory:percent
        expr: redis_memory_used_bytes / redis_memory_max_bytes * 100
