#!/bin/bash
# Ablage-System Backup Script
# Generated by Ansible - Do not edit manually
# Usage: ablage-backup [--full|--db-only|--files-only]

set -e

# Configuration
BACKUP_DIR="{{ ablage_backup_dir }}"
INSTALL_DIR="{{ ablage_install_dir }}"
RETENTION_DAYS={{ backup_retention_days | default(30) }}
DATE=$(date +%Y%m%d_%H%M%S)
LOG_FILE="${BACKUP_DIR}/logs/backup.log"

# Remote sync configuration
REMOTE_ENABLED="{{ backup_remote_enabled | default(false) | lower }}"
{% if backup_remote_enabled | default(false) %}
REMOTE_USER="{{ vault_backup_remote_user }}"
REMOTE_HOST="{{ vault_backup_remote_host }}"
REMOTE_PATH="{{ vault_backup_remote_path }}"
SSH_KEY="/home/ablage/.ssh/backup_key"
{% endif %}

# Logging function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

# Error handling
error_exit() {
    log "ERROR: $1"
    exit 1
}

# Check if Docker is running
check_docker() {
    docker info >/dev/null 2>&1 || error_exit "Docker is not running"
}

# Backup PostgreSQL
backup_postgres() {
    log "Backing up PostgreSQL database..."
    local backup_file="${BACKUP_DIR}/postgres/ablage_${DATE}.sql.gz"

    docker compose -f "${INSTALL_DIR}/docker-compose.yml" exec -T postgres \
        pg_dump -U ablage_admin ablage_system | gzip > "$backup_file" \
        || error_exit "PostgreSQL backup failed"

    log "PostgreSQL backup saved to: $backup_file"
    echo "$backup_file"
}

# Backup Redis
backup_redis() {
    log "Backing up Redis data..."
    local backup_file="${BACKUP_DIR}/redis/dump_${DATE}.rdb"

    # Trigger Redis background save
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" exec -T redis \
        redis-cli BGSAVE >/dev/null

    # Wait for save to complete
    sleep 5

    # Copy dump file
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" cp \
        redis:/data/dump.rdb "$backup_file" \
        || log "WARNING: Redis backup may have failed"

    log "Redis backup saved to: $backup_file"
}

# Backup MinIO (documents)
backup_minio() {
    log "Backing up MinIO data..."
    local backup_dir="${BACKUP_DIR}/minio/${DATE}"
    mkdir -p "$backup_dir"

    # Use mc (MinIO client) if available, otherwise copy volume
    if command -v mc &> /dev/null; then
        mc mirror local/documents "$backup_dir/" --overwrite 2>/dev/null \
            || log "WARNING: MinIO mirror may have failed"
    else
        log "MinIO client not available, skipping document backup"
    fi

    log "MinIO backup saved to: $backup_dir"
}

# Backup configuration
backup_config() {
    log "Backing up configuration..."
    local backup_file="${BACKUP_DIR}/config/config_${DATE}.tar.gz"

    tar -czf "$backup_file" \
        -C "${INSTALL_DIR}" \
        .env \
        docker-compose.yml \
        docker-compose.override.yml 2>/dev/null \
        || tar -czf "$backup_file" \
            -C "${INSTALL_DIR}" \
            .env \
            docker-compose.yml

    log "Configuration backup saved to: $backup_file"
}

# Sync to remote
sync_remote() {
    if [ "$REMOTE_ENABLED" != "true" ]; then
        return
    fi

    log "Syncing backups to remote storage..."

    rsync -avz --delete \
        -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no" \
        "${BACKUP_DIR}/" \
        "${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_PATH}/" \
        || log "WARNING: Remote sync failed"

    log "Remote sync completed"
}

# Main backup function
main() {
    local backup_type="${1:-full}"

    log "=========================================="
    log "Starting Ablage-System backup (${backup_type})"
    log "=========================================="

    check_docker

    case "$backup_type" in
        --full|full)
            backup_postgres
            backup_redis
            backup_minio
            backup_config
            ;;
        --db-only|db-only)
            backup_postgres
            backup_redis
            ;;
        --files-only|files-only)
            backup_minio
            backup_config
            ;;
        *)
            echo "Usage: $0 [--full|--db-only|--files-only]"
            exit 1
            ;;
    esac

    sync_remote

    log "=========================================="
    log "Backup completed successfully"
    log "=========================================="
}

main "$@"
