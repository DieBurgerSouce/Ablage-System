#!/bin/bash
# Ablage-System Backup Cleanup Script
# Generated by Ansible - Do not edit manually

set -e

BACKUP_DIR="{{ ablage_backup_dir }}"
RETENTION_DAYS={{ backup_retention_days | default(30) }}
LOG_FILE="${BACKUP_DIR}/logs/backup.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] CLEANUP: $1" | tee -a "$LOG_FILE"
}

log "Starting backup cleanup (retention: ${RETENTION_DAYS} days)"

# Clean up old PostgreSQL backups
find "${BACKUP_DIR}/postgres" -type f -name "*.sql.gz" -mtime +${RETENTION_DAYS} -delete 2>/dev/null
log "Cleaned PostgreSQL backups older than ${RETENTION_DAYS} days"

# Clean up old Redis backups
find "${BACKUP_DIR}/redis" -type f -name "*.rdb" -mtime +${RETENTION_DAYS} -delete 2>/dev/null
log "Cleaned Redis backups older than ${RETENTION_DAYS} days"

# Clean up old MinIO backups (directories)
find "${BACKUP_DIR}/minio" -type d -mtime +${RETENTION_DAYS} -exec rm -rf {} + 2>/dev/null || true
log "Cleaned MinIO backups older than ${RETENTION_DAYS} days"

# Clean up old config backups
find "${BACKUP_DIR}/config" -type f -name "*.tar.gz" -mtime +${RETENTION_DAYS} -delete 2>/dev/null
log "Cleaned config backups older than ${RETENTION_DAYS} days"

# Report disk usage
log "Current backup disk usage:"
du -sh "${BACKUP_DIR}"/* 2>/dev/null | while read line; do
    log "  $line"
done

log "Backup cleanup completed"
