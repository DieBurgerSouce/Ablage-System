#!/bin/bash
# Ablage-System Restore Script
# Generated by Ansible - Do not edit manually
# Usage: ablage-restore [--list|--restore DATE]

set -e

# Configuration
BACKUP_DIR="{{ ablage_backup_dir }}"
INSTALL_DIR="{{ ablage_install_dir }}"
LOG_FILE="${BACKUP_DIR}/logs/restore.log"

# Logging function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

# List available backups
list_backups() {
    echo "Available PostgreSQL backups:"
    ls -la "${BACKUP_DIR}/postgres/" 2>/dev/null || echo "  No backups found"
    echo ""
    echo "Available Redis backups:"
    ls -la "${BACKUP_DIR}/redis/" 2>/dev/null || echo "  No backups found"
    echo ""
    echo "Available configuration backups:"
    ls -la "${BACKUP_DIR}/config/" 2>/dev/null || echo "  No backups found"
}

# Restore PostgreSQL
restore_postgres() {
    local backup_date="$1"
    local backup_file="${BACKUP_DIR}/postgres/ablage_${backup_date}.sql.gz"

    if [ ! -f "$backup_file" ]; then
        log "ERROR: PostgreSQL backup not found: $backup_file"
        return 1
    fi

    log "Restoring PostgreSQL from: $backup_file"

    # Stop dependent services
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" stop backend worker

    # Restore database
    gunzip -c "$backup_file" | docker compose -f "${INSTALL_DIR}/docker-compose.yml" exec -T postgres \
        psql -U ablage_admin -d ablage_system

    # Restart services
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" start backend worker

    log "PostgreSQL restore completed"
}

# Restore Redis
restore_redis() {
    local backup_date="$1"
    local backup_file="${BACKUP_DIR}/redis/dump_${backup_date}.rdb"

    if [ ! -f "$backup_file" ]; then
        log "ERROR: Redis backup not found: $backup_file"
        return 1
    fi

    log "Restoring Redis from: $backup_file"

    # Stop Redis
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" stop redis

    # Copy backup file
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" cp \
        "$backup_file" redis:/data/dump.rdb

    # Start Redis
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" start redis

    log "Redis restore completed"
}

# Restore configuration
restore_config() {
    local backup_date="$1"
    local backup_file="${BACKUP_DIR}/config/config_${backup_date}.tar.gz"

    if [ ! -f "$backup_file" ]; then
        log "ERROR: Configuration backup not found: $backup_file"
        return 1
    fi

    log "Restoring configuration from: $backup_file"

    # Backup current config
    cp "${INSTALL_DIR}/.env" "${INSTALL_DIR}/.env.pre-restore" 2>/dev/null || true

    # Extract backup
    tar -xzf "$backup_file" -C "${INSTALL_DIR}/"

    log "Configuration restore completed"
    log "NOTE: Restart services with: systemctl restart ablage-system"
}

# Main restore function
main() {
    case "$1" in
        --list|list)
            list_backups
            ;;
        --restore|restore)
            if [ -z "$2" ]; then
                echo "Usage: $0 --restore DATE [--postgres|--redis|--config|--all]"
                echo "Example: $0 --restore 20240115_020000 --all"
                exit 1
            fi

            local backup_date="$2"
            local restore_type="${3:---all}"

            log "=========================================="
            log "Starting Ablage-System restore"
            log "Backup date: $backup_date"
            log "=========================================="

            case "$restore_type" in
                --postgres)
                    restore_postgres "$backup_date"
                    ;;
                --redis)
                    restore_redis "$backup_date"
                    ;;
                --config)
                    restore_config "$backup_date"
                    ;;
                --all)
                    restore_postgres "$backup_date"
                    restore_redis "$backup_date"
                    restore_config "$backup_date"
                    ;;
            esac

            log "=========================================="
            log "Restore completed"
            log "=========================================="
            ;;
        *)
            echo "Usage: $0 [--list|--restore DATE]"
            exit 1
            ;;
    esac
}

main "$@"
