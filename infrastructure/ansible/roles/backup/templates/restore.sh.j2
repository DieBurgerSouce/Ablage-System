#!/bin/bash
# Ablage-System Restore Script
# Generated by Ansible - Do not edit manually
# Usage: ablage-restore [--list|--restore DATE [--component]]

set -e

# Configuration
BACKUP_DIR="{{ ablage_backup_dir }}"
INSTALL_DIR="{{ ablage_install_dir }}"
LOG_FILE="${BACKUP_DIR}/logs/restore.log"

# Encryption configuration
ENCRYPTION_ENABLED="{{ backup_encryption_enabled | default(false) | lower }}"
{% if backup_encryption_enabled | default(false) %}
GPG_HOME="${BACKUP_DIR}/.gnupg"
GPG_PASSPHRASE_FILE="${GPG_HOME}/passphrase"
{% endif %}

# Metrics configuration
METRICS_ENABLED="{{ backup_metrics_enabled | default(true) | lower }}"
METRICS_FILE="{{ backup_metrics_file | default('/var/lib/prometheus/node-exporter/ablage_backup.prom') }}"

# =============================================================================
# Logging Functions
# =============================================================================

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

error_exit() {
    log "FEHLER: $1"
    emit_restore_failure "$1"
    exit 1
}

# =============================================================================
# Metrics Functions
# =============================================================================

emit_restore_success() {
    if [ "$METRICS_ENABLED" != "true" ]; then
        return
    fi

    local temp_file="${METRICS_FILE}.tmp"

    local current_success=0
    if [ -f "$METRICS_FILE" ]; then
        current_success=$(grep "ablage_backup_restore_success_total" "$METRICS_FILE" 2>/dev/null | awk '{print $2}' || echo "0")
        grep -v "ablage_backup_restore_" "$METRICS_FILE" > "$temp_file" 2>/dev/null || true
    fi
    current_success=$((current_success + 1))

    cat >> "$temp_file" << EOF
# HELP ablage_backup_restore_success_total Anzahl erfolgreicher Wiederherstellungen
# TYPE ablage_backup_restore_success_total counter
ablage_backup_restore_success_total ${current_success}
# HELP ablage_backup_restore_last_success_timestamp Unix-Zeitstempel der letzten erfolgreichen Wiederherstellung
# TYPE ablage_backup_restore_last_success_timestamp gauge
ablage_backup_restore_last_success_timestamp $(date +%s)
EOF

    mv "$temp_file" "$METRICS_FILE"
    chmod 644 "$METRICS_FILE"

    log "Metriken aktualisiert: Wiederherstellung erfolgreich"
}

emit_restore_failure() {
    if [ "$METRICS_ENABLED" != "true" ]; then
        return
    fi

    local error_message="$1"
    local temp_file="${METRICS_FILE}.tmp"

    local current_failure=0
    if [ -f "$METRICS_FILE" ]; then
        current_failure=$(grep "ablage_backup_restore_failure_total" "$METRICS_FILE" 2>/dev/null | awk '{print $2}' || echo "0")
        grep -v "ablage_backup_restore_failure" "$METRICS_FILE" > "$temp_file" 2>/dev/null || true
    fi
    current_failure=$((current_failure + 1))

    cat >> "$temp_file" << EOF
# HELP ablage_backup_restore_failure_total Anzahl fehlgeschlagener Wiederherstellungen
# TYPE ablage_backup_restore_failure_total counter
ablage_backup_restore_failure_total ${current_failure}
EOF

    mv "$temp_file" "$METRICS_FILE"
    chmod 644 "$METRICS_FILE"

    log "Metriken aktualisiert: Wiederherstellung fehlgeschlagen (${error_message})"
}

# =============================================================================
# Decryption Functions
# =============================================================================

decrypt_file() {
    local input_file="$1"

    # Check if file is encrypted
    if [[ ! "$input_file" == *.gpg ]]; then
        echo "$input_file"
        return
    fi

    if [ "$ENCRYPTION_ENABLED" != "true" ]; then
        error_exit "Backup ist verschluesselt aber Entschluesselung nicht konfiguriert"
    fi

    local output_file="${input_file%.gpg}"

    log "Entschluessele Backup: $(basename "$input_file")"

    # Check for passphrase file
    if [ ! -f "$GPG_PASSPHRASE_FILE" ]; then
        error_exit "GPG-Passphrase-Datei nicht gefunden: $GPG_PASSPHRASE_FILE"
    fi

    gpg --homedir "$GPG_HOME" \
        --batch \
        --yes \
        --pinentry-mode loopback \
        --passphrase-file "$GPG_PASSPHRASE_FILE" \
        --output "$output_file" \
        --decrypt "$input_file" \
        || error_exit "GPG-Entschluesselung fehlgeschlagen fuer: $input_file"

    log "Entschluesselung abgeschlossen: $(basename "$output_file")"
    echo "$output_file"
}

find_backup_file() {
    local base_pattern="$1"

    # Try encrypted version first if encryption is enabled
    if [ "$ENCRYPTION_ENABLED" == "true" ]; then
        if [ -f "${base_pattern}.gpg" ]; then
            echo "${base_pattern}.gpg"
            return
        fi
    fi

    # Try unencrypted version
    if [ -f "$base_pattern" ]; then
        echo "$base_pattern"
        return
    fi

    # Not found
    echo ""
}

# =============================================================================
# Listing Functions
# =============================================================================

list_backups() {
    echo ""
    echo "=== Verfuegbare Backups ==="
    echo ""

    echo "PostgreSQL-Backups:"
    if ls -la "${BACKUP_DIR}/postgres/" 2>/dev/null | grep -E '\.(sql\.gz|sql\.gz\.gpg)$'; then
        :
    else
        echo "  Keine Backups gefunden"
    fi

    echo ""
    echo "Redis-Backups:"
    if ls -la "${BACKUP_DIR}/redis/" 2>/dev/null | grep -E '\.(rdb|rdb\.gpg)$'; then
        :
    else
        echo "  Keine Backups gefunden"
    fi

    echo ""
    echo "MinIO-Backups:"
    if ls -la "${BACKUP_DIR}/minio/" 2>/dev/null | grep -E '\.(tar\.gz|tar\.gz\.gpg)$'; then
        :
    else
        echo "  Keine Backups gefunden"
    fi

    echo ""
    echo "Konfigurations-Backups:"
    if ls -la "${BACKUP_DIR}/config/" 2>/dev/null | grep -E '\.(tar\.gz|tar\.gz\.gpg)$'; then
        :
    else
        echo "  Keine Backups gefunden"
    fi

    echo ""
    echo "Verschluesselung: $([ "$ENCRYPTION_ENABLED" == "true" ] && echo "AKTIVIERT (.gpg Dateien)" || echo "DEAKTIVIERT")"
    echo ""
}

# =============================================================================
# Restore Functions
# =============================================================================

restore_postgres() {
    local backup_date="$1"
    local base_file="${BACKUP_DIR}/postgres/ablage_${backup_date}.sql.gz"

    local backup_file=$(find_backup_file "$base_file")

    if [ -z "$backup_file" ] || [ ! -f "$backup_file" ]; then
        log "FEHLER: PostgreSQL-Backup nicht gefunden: $base_file[.gpg]"
        return 1
    fi

    log "Stelle PostgreSQL wieder her von: $backup_file"

    # Decrypt if necessary
    local work_file=$(decrypt_file "$backup_file")

    # Stop dependent services
    log "Stoppe abhaengige Dienste..."
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" stop backend worker || true

    # Restore database
    log "Stelle Datenbank wieder her..."
    gunzip -c "$work_file" | docker compose -f "${INSTALL_DIR}/docker-compose.yml" exec -T postgres \
        psql -U ablage_admin -d ablage_system

    # Remove decrypted temp file if it was created
    if [ "$work_file" != "$backup_file" ]; then
        rm -f "$work_file"
    fi

    # Restart services
    log "Starte Dienste neu..."
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" start backend worker

    log "PostgreSQL-Wiederherstellung abgeschlossen"
}

restore_redis() {
    local backup_date="$1"
    local base_file="${BACKUP_DIR}/redis/dump_${backup_date}.rdb"

    local backup_file=$(find_backup_file "$base_file")

    if [ -z "$backup_file" ] || [ ! -f "$backup_file" ]; then
        log "FEHLER: Redis-Backup nicht gefunden: $base_file[.gpg]"
        return 1
    fi

    log "Stelle Redis wieder her von: $backup_file"

    # Decrypt if necessary
    local work_file=$(decrypt_file "$backup_file")

    # Stop Redis
    log "Stoppe Redis..."
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" stop redis

    # Copy backup file
    log "Kopiere Backup-Datei..."
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" cp \
        "$work_file" redis:/data/dump.rdb

    # Remove decrypted temp file if it was created
    if [ "$work_file" != "$backup_file" ]; then
        rm -f "$work_file"
    fi

    # Start Redis
    log "Starte Redis..."
    docker compose -f "${INSTALL_DIR}/docker-compose.yml" start redis

    log "Redis-Wiederherstellung abgeschlossen"
}

restore_minio() {
    local backup_date="$1"
    local base_file="${BACKUP_DIR}/minio/minio_${backup_date}.tar.gz"

    local backup_file=$(find_backup_file "$base_file")

    if [ -z "$backup_file" ] || [ ! -f "$backup_file" ]; then
        log "FEHLER: MinIO-Backup nicht gefunden: $base_file[.gpg]"
        return 1
    fi

    log "Stelle MinIO wieder her von: $backup_file"

    # Decrypt if necessary
    local work_file=$(decrypt_file "$backup_file")

    # Extract to temp directory
    local temp_dir="${BACKUP_DIR}/minio/restore_temp_$$"
    mkdir -p "$temp_dir"

    log "Extrahiere Backup-Archiv..."
    tar -xzf "$work_file" -C "$temp_dir"

    # Use mc to restore if available
    if command -v mc &> /dev/null; then
        log "Stelle Dokumente via MinIO-Client wieder her..."
        mc mirror "$temp_dir/${backup_date}/" local/documents/ --overwrite 2>/dev/null \
            || log "WARNUNG: MinIO-Mirror moeglicherweise fehlgeschlagen"
    else
        log "WARNUNG: MinIO-Client nicht verfuegbar, manuelle Wiederherstellung erforderlich"
    fi

    # Cleanup
    rm -rf "$temp_dir"
    if [ "$work_file" != "$backup_file" ]; then
        rm -f "$work_file"
    fi

    log "MinIO-Wiederherstellung abgeschlossen"
}

restore_config() {
    local backup_date="$1"
    local base_file="${BACKUP_DIR}/config/config_${backup_date}.tar.gz"

    local backup_file=$(find_backup_file "$base_file")

    if [ -z "$backup_file" ] || [ ! -f "$backup_file" ]; then
        log "FEHLER: Konfigurations-Backup nicht gefunden: $base_file[.gpg]"
        return 1
    fi

    log "Stelle Konfiguration wieder her von: $backup_file"

    # Decrypt if necessary
    local work_file=$(decrypt_file "$backup_file")

    # Backup current config
    log "Sichere aktuelle Konfiguration..."
    cp "${INSTALL_DIR}/.env" "${INSTALL_DIR}/.env.pre-restore" 2>/dev/null || true
    cp "${INSTALL_DIR}/docker-compose.yml" "${INSTALL_DIR}/docker-compose.yml.pre-restore" 2>/dev/null || true

    # Extract backup
    log "Extrahiere Konfigurations-Backup..."
    tar -xzf "$work_file" -C "${INSTALL_DIR}/"

    # Remove decrypted temp file if it was created
    if [ "$work_file" != "$backup_file" ]; then
        rm -f "$work_file"
    fi

    log "Konfigurations-Wiederherstellung abgeschlossen"
    log "HINWEIS: Starten Sie die Dienste neu mit: systemctl restart ablage-system"
}

# =============================================================================
# Confirmation Dialog
# =============================================================================

confirm_restore() {
    local backup_date="$1"
    local restore_type="$2"

    echo ""
    echo "!!! WARNUNG !!!"
    echo ""
    echo "Sie sind dabei, eine Wiederherstellung durchzufuehren:"
    echo "  Backup-Datum: $backup_date"
    echo "  Komponenten:  $restore_type"
    echo ""
    echo "Diese Aktion wird vorhandene Daten UEBERSCHREIBEN!"
    echo ""
    read -p "Sind Sie sicher? (ja/nein): " confirm

    if [ "$confirm" != "ja" ]; then
        echo "Wiederherstellung abgebrochen."
        exit 0
    fi
}

# =============================================================================
# Test Restore (for validation)
# =============================================================================

test_restore() {
    local backup_date="$1"

    log "=========================================="
    log "Starte Wiederherstellungstest"
    log "Backup-Datum: $backup_date"
    log "=========================================="

    local test_success=true
    local test_results=""

    # Test PostgreSQL backup can be decrypted and read
    local pg_base="${BACKUP_DIR}/postgres/ablage_${backup_date}.sql.gz"
    local pg_file=$(find_backup_file "$pg_base")

    if [ -n "$pg_file" ] && [ -f "$pg_file" ]; then
        log "Teste PostgreSQL-Backup..."
        local pg_work=$(decrypt_file "$pg_file")

        if gunzip -t "$pg_work" 2>/dev/null; then
            test_results="$test_results\n  PostgreSQL: OK"
            log "PostgreSQL-Backup: OK"
        else
            test_results="$test_results\n  PostgreSQL: FEHLER (ungueltige Komprimierung)"
            log "PostgreSQL-Backup: FEHLER"
            test_success=false
        fi

        if [ "$pg_work" != "$pg_file" ]; then
            rm -f "$pg_work"
        fi
    else
        test_results="$test_results\n  PostgreSQL: NICHT GEFUNDEN"
        log "PostgreSQL-Backup: NICHT GEFUNDEN"
    fi

    # Test config backup can be decrypted and read
    local config_base="${BACKUP_DIR}/config/config_${backup_date}.tar.gz"
    local config_file=$(find_backup_file "$config_base")

    if [ -n "$config_file" ] && [ -f "$config_file" ]; then
        log "Teste Konfigurations-Backup..."
        local config_work=$(decrypt_file "$config_file")

        if tar -tzf "$config_work" >/dev/null 2>&1; then
            test_results="$test_results\n  Konfiguration: OK"
            log "Konfigurations-Backup: OK"
        else
            test_results="$test_results\n  Konfiguration: FEHLER (ungueltige Archivdatei)"
            log "Konfigurations-Backup: FEHLER"
            test_success=false
        fi

        if [ "$config_work" != "$config_file" ]; then
            rm -f "$config_work"
        fi
    else
        test_results="$test_results\n  Konfiguration: NICHT GEFUNDEN"
        log "Konfigurations-Backup: NICHT GEFUNDEN"
    fi

    echo ""
    echo "=== Testergebnisse ==="
    echo -e "$test_results"
    echo ""

    if [ "$test_success" == "true" ]; then
        log "Wiederherstellungstest: ERFOLGREICH"
        emit_restore_test_success
        return 0
    else
        log "Wiederherstellungstest: FEHLGESCHLAGEN"
        emit_restore_test_failure "Backup-Validierung fehlgeschlagen"
        return 1
    fi
}

emit_restore_test_success() {
    if [ "$METRICS_ENABLED" != "true" ]; then
        return
    fi

    local temp_file="${METRICS_FILE}.tmp"

    local current_success=0
    if [ -f "$METRICS_FILE" ]; then
        current_success=$(grep "ablage_backup_restore_test_success_total" "$METRICS_FILE" 2>/dev/null | awk '{print $2}' || echo "0")
        grep -v "ablage_backup_restore_test_" "$METRICS_FILE" > "$temp_file" 2>/dev/null || true
    fi
    current_success=$((current_success + 1))

    cat >> "$temp_file" << EOF
# HELP ablage_backup_restore_test_success_total Anzahl erfolgreicher Wiederherstellungstests
# TYPE ablage_backup_restore_test_success_total counter
ablage_backup_restore_test_success_total ${current_success}
# HELP ablage_backup_restore_test_last_success_timestamp Unix-Zeitstempel des letzten erfolgreichen Tests
# TYPE ablage_backup_restore_test_last_success_timestamp gauge
ablage_backup_restore_test_last_success_timestamp $(date +%s)
EOF

    mv "$temp_file" "$METRICS_FILE"
    chmod 644 "$METRICS_FILE"
}

emit_restore_test_failure() {
    if [ "$METRICS_ENABLED" != "true" ]; then
        return
    fi

    local temp_file="${METRICS_FILE}.tmp"

    local current_failure=0
    if [ -f "$METRICS_FILE" ]; then
        current_failure=$(grep "ablage_backup_restore_test_failure_total" "$METRICS_FILE" 2>/dev/null | awk '{print $2}' || echo "0")
        grep -v "ablage_backup_restore_test_failure" "$METRICS_FILE" > "$temp_file" 2>/dev/null || true
    fi
    current_failure=$((current_failure + 1))

    cat >> "$temp_file" << EOF
# HELP ablage_backup_restore_test_failure_total Anzahl fehlgeschlagener Wiederherstellungstests
# TYPE ablage_backup_restore_test_failure_total counter
ablage_backup_restore_test_failure_total ${current_failure}
EOF

    mv "$temp_file" "$METRICS_FILE"
    chmod 644 "$METRICS_FILE"
}

# =============================================================================
# Main Function
# =============================================================================

main() {
    case "$1" in
        --list|list)
            list_backups
            ;;

        --test|test)
            if [ -z "$2" ]; then
                # Find most recent backup
                local latest=$(ls -1 "${BACKUP_DIR}/postgres/" 2>/dev/null | grep -oP '\d{8}_\d{6}' | sort -r | head -1)
                if [ -z "$latest" ]; then
                    echo "Keine Backups gefunden fuer Test"
                    exit 1
                fi
                test_restore "$latest"
            else
                test_restore "$2"
            fi
            ;;

        --restore|restore)
            if [ -z "$2" ]; then
                echo "Verwendung: $0 --restore DATUM [--postgres|--redis|--minio|--config|--all]"
                echo "Beispiel: $0 --restore 20240115_020000 --all"
                echo ""
                echo "Optionen:"
                echo "  --postgres  Nur PostgreSQL-Datenbank wiederherstellen"
                echo "  --redis     Nur Redis-Daten wiederherstellen"
                echo "  --minio     Nur MinIO-Dokumente wiederherstellen"
                echo "  --config    Nur Konfiguration wiederherstellen"
                echo "  --all       Alles wiederherstellen (Standard)"
                exit 1
            fi

            local backup_date="$2"
            local restore_type="${3:---all}"

            # Confirm before proceeding
            confirm_restore "$backup_date" "$restore_type"

            log "=========================================="
            log "Starte Ablage-System Wiederherstellung"
            log "Backup-Datum: $backup_date"
            log "Verschluesselung: $([ "$ENCRYPTION_ENABLED" == "true" ] && echo "AKTIVIERT" || echo "DEAKTIVIERT")"
            log "=========================================="

            local restore_success=true

            case "$restore_type" in
                --postgres)
                    restore_postgres "$backup_date" || restore_success=false
                    ;;
                --redis)
                    restore_redis "$backup_date" || restore_success=false
                    ;;
                --minio)
                    restore_minio "$backup_date" || restore_success=false
                    ;;
                --config)
                    restore_config "$backup_date" || restore_success=false
                    ;;
                --all)
                    restore_postgres "$backup_date" || restore_success=false
                    restore_redis "$backup_date" || restore_success=false
                    restore_minio "$backup_date" || restore_success=false
                    restore_config "$backup_date" || restore_success=false
                    ;;
                *)
                    echo "Unbekannte Option: $restore_type"
                    exit 1
                    ;;
            esac

            if [ "$restore_success" == "true" ]; then
                emit_restore_success
                log "=========================================="
                log "Wiederherstellung erfolgreich abgeschlossen"
                log "=========================================="
            else
                emit_restore_failure "Teilweise fehlgeschlagen"
                log "=========================================="
                log "Wiederherstellung mit Fehlern abgeschlossen"
                log "=========================================="
                exit 1
            fi
            ;;

        *)
            echo "Ablage-System Wiederherstellungs-Tool"
            echo ""
            echo "Verwendung: $0 [BEFEHL] [OPTIONEN]"
            echo ""
            echo "Befehle:"
            echo "  --list              Verfuegbare Backups anzeigen"
            echo "  --restore DATUM     Backup wiederherstellen"
            echo "  --test [DATUM]      Wiederherstellungstest durchfuehren"
            echo ""
            echo "Beispiele:"
            echo "  $0 --list"
            echo "  $0 --restore 20240115_020000 --all"
            echo "  $0 --test"
            exit 1
            ;;
    esac
}

main "$@"
