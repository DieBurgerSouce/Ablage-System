[Unit]
Description=Ablage-System Backup Service
Documentation=https://github.com/org/ablage-system
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/ablage-backup --full
User=root
Group=root

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ablage-backup
