# GPG Agent Configuration for Ablage-System Backups
# Generated by Ansible - Do not edit manually

# Cache passphrase for 24 hours (for automated operations)
default-cache-ttl 86400
max-cache-ttl 86400

# Allow loopback pinentry for scripted operations
allow-loopback-pinentry

# Log to syslog
log-file /var/log/ablage-system/gpg-agent.log
