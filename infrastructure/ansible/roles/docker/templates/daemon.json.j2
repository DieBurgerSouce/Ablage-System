{
{% if docker_nvidia_runtime | default(false) %}
  "default-runtime": "nvidia",
  "runtimes": {
    "nvidia": {
      "path": "nvidia-container-runtime",
      "runtimeArgs": []
    }
  },
{% endif %}
  "storage-driver": "{{ docker_storage_driver | default('overlay2') }}",
  "log-driver": "{{ docker_log_driver | default('json-file') }}",
  "log-opts": {
    "max-size": "{{ docker_log_max_size | default('100m') }}",
    "max-file": "{{ docker_log_max_file | default('5') }}"
  },
  "live-restore": {{ docker_live_restore | default(true) | lower }},
  "default-ulimits": {
    "nofile": {
      "Name": "nofile",
      "Hard": {{ docker_ulimits_nofile_hard | default(65535) }},
      "Soft": {{ docker_ulimits_nofile_soft | default(65535) }}
    }
  },
{% if docker_dns | default([]) | length > 0 %}
  "dns": {{ docker_dns | to_json }},
{% endif %}
{% if docker_insecure_registries | default([]) | length > 0 %}
  "insecure-registries": {{ docker_insecure_registries | to_json }},
{% endif %}
{% if docker_registry_mirrors | default([]) | length > 0 %}
  "registry-mirrors": {{ docker_registry_mirrors | to_json }},
{% endif %}
  "default-address-pools": [
{% for pool in docker_default_address_pools | default([{'base': '172.17.0.0/12', 'size': 24}]) %}
    {
      "base": "{{ pool.base }}",
      "size": {{ pool.size }}
    }{% if not loop.last %},{% endif %}

{% endfor %}
  ],
  "features": {
    "buildkit": true
  },
  "experimental": false
}
