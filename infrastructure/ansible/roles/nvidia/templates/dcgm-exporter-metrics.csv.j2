# DCGM Exporter Metrics Configuration
# Ablage-System OCR GPU Monitoring
# Created: 2025-12-09
#
# Format: DCGM_FIELD_NAME, Prometheus_Metric_Name, Prometheus_Label_Type
#
# Die Metriken werden von Prometheus unter DCGM_FI_* erfasst
# und in den Alert Rules referenziert.

# GPU Identification
DCGM_FI_DEV_NAME,                   gpu_name,                          gauge
DCGM_FI_DEV_BRAND,                  gpu_brand,                         gauge
DCGM_FI_DEV_SERIAL,                 gpu_serial,                        gauge
DCGM_FI_DRIVER_VERSION,             driver_version,                    gauge

# GPU Memory (kritisch fuer OCR-Workloads)
DCGM_FI_DEV_FB_TOTAL,               gpu_fb_memory_total_bytes,         gauge
DCGM_FI_DEV_FB_FREE,                gpu_fb_memory_free_bytes,          gauge
DCGM_FI_DEV_FB_USED,                gpu_fb_memory_used_bytes,          gauge
DCGM_FI_DEV_BAR1_TOTAL,             gpu_bar1_memory_total_bytes,       gauge
DCGM_FI_DEV_BAR1_USED,              gpu_bar1_memory_used_bytes,        gauge

# GPU Utilization
DCGM_FI_DEV_GPU_UTIL,               gpu_utilization,                   gauge
DCGM_FI_DEV_MEM_COPY_UTIL,          gpu_memory_copy_utilization,       gauge
DCGM_FI_DEV_ENC_UTIL,               gpu_encoder_utilization,           gauge
DCGM_FI_DEV_DEC_UTIL,               gpu_decoder_utilization,           gauge

# GPU Temperature (wichtig fuer Thermal Throttling Alerts)
DCGM_FI_DEV_GPU_TEMP,               gpu_temperature_celsius,           gauge
DCGM_FI_DEV_MEMORY_TEMP,            gpu_memory_temperature_celsius,    gauge

# GPU Power (fuer Power Limit Alerts)
DCGM_FI_DEV_POWER_USAGE,            gpu_power_usage_watts,             gauge
DCGM_FI_DEV_TOTAL_ENERGY_CONSUMPTION, gpu_total_energy_consumption_mj, counter
DCGM_FI_DEV_POWER_LIMIT,            gpu_power_limit_watts,             gauge

# GPU Clock Speeds
DCGM_FI_DEV_SM_CLOCK,               gpu_sm_clock_mhz,                  gauge
DCGM_FI_DEV_MEM_CLOCK,              gpu_memory_clock_mhz,              gauge

# GPU PCIe
DCGM_FI_DEV_PCIE_TX_THROUGHPUT,     gpu_pcie_tx_bytes,                 counter
DCGM_FI_DEV_PCIE_RX_THROUGHPUT,     gpu_pcie_rx_bytes,                 counter
DCGM_FI_DEV_PCIE_LINK_GEN,          gpu_pcie_link_generation,          gauge
DCGM_FI_DEV_PCIE_LINK_WIDTH,        gpu_pcie_link_width,               gauge

# GPU Errors (ECC fuer Datenintegritaet)
DCGM_FI_DEV_ECC_SBE_VOL_TOTAL,      gpu_ecc_single_bit_errors,         counter
DCGM_FI_DEV_ECC_DBE_VOL_TOTAL,      gpu_ecc_double_bit_errors,         counter
DCGM_FI_DEV_RETIRED_SBE,            gpu_retired_pages_single_bit,      counter
DCGM_FI_DEV_RETIRED_DBE,            gpu_retired_pages_double_bit,      counter

# GPU Process Info (falls verfuegbar)
DCGM_FI_DEV_COMPUTE_MODE,           gpu_compute_mode,                  gauge

# Zusaetzliche Metriken fuer OCR-Workload-Monitoring
# Diese helfen beim Debugging von Performance-Problemen
DCGM_FI_PROF_GR_ENGINE_ACTIVE,      gpu_gr_engine_active,              gauge
DCGM_FI_PROF_SM_ACTIVE,             gpu_sm_active,                     gauge
DCGM_FI_PROF_SM_OCCUPANCY,          gpu_sm_occupancy,                  gauge
DCGM_FI_PROF_DRAM_ACTIVE,           gpu_dram_active,                   gauge
