# Sentry Configuration - Ablage-System OCR

# Sentry DSN (Data Source Name)
# Get this from: https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Environment (development, staging, production)
ENVIRONMENT=production

# Application version/release
# Should match your git tag or version number
VERSION=0.1.0

# Sampling rates (0.0 to 1.0)
# Percentage of transactions to trace
SENTRY_TRACES_SAMPLE_RATE=0.1

# Percentage of transactions to profile
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Worker sampling (usually lower than backend)
SENTRY_WORKER_TRACES_SAMPLE_RATE=0.05
SENTRY_WORKER_PROFILES_SAMPLE_RATE=0.05

# Enable/disable tracing
SENTRY_ENABLE_TRACING=true

# Slow request threshold (milliseconds)
SENTRY_SLOW_REQUEST_THRESHOLD_MS=1000
