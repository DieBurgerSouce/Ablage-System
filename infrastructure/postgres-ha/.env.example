# PostgreSQL HA Cluster - Umgebungsvariablen
# Ablage-System Enterprise Database Configuration
#
# WICHTIG: Diese Datei nach .env kopieren und Werte anpassen!
# cp .env.example .env

# ============================================================
# PostgreSQL Credentials
# ============================================================

# Superuser-Passwort (admin/postgres)
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_32_CHARS

# Replikations-Benutzer Passwort
REPLICATION_PASSWORD=CHANGE_ME_REPLICATION_PASSWORD

# ============================================================
# Patroni REST API
# ============================================================

# REST API Authentifizierung
PATRONI_RESTAPI_USER=patroni
PATRONI_RESTAPI_PASSWORD=CHANGE_ME_PATRONI_API_PASSWORD

# ============================================================
# HAProxy Stats
# ============================================================

# HAProxy Stats-Seite Zugang (http://localhost:7000/stats)
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=CHANGE_ME_HAPROXY_PASSWORD

# ============================================================
# Ablage-System Integration
# ============================================================

# Datenbank-URL fuer Ablage-System Backend
# Primary (Read/Write):
DATABASE_URL=postgresql+asyncpg://ablage_admin:CHANGE_ME@localhost:5432/ablage_system

# Read-Only URL fuer Leseoperationen (optional):
DATABASE_URL_READONLY=postgresql+asyncpg://ablage_admin:CHANGE_ME@localhost:5433/ablage_system
