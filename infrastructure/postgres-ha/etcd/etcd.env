# etcd Cluster Konfiguration fuer Ablage-System PostgreSQL HA
# 3-Node etcd Cluster fuer Patroni DCS (Distributed Configuration Store)

# Cluster-weite Einstellungen
ETCD_CLUSTER_TOKEN=ablage-etcd-cluster

# Node 1 Konfiguration (etcd1)
ETCD1_NAME=etcd1
ETCD1_INITIAL_ADVERTISE_PEER_URLS=http://etcd1:2380
ETCD1_LISTEN_PEER_URLS=http://0.0.0.0:2380
ETCD1_ADVERTISE_CLIENT_URLS=http://etcd1:2379
ETCD1_LISTEN_CLIENT_URLS=http://0.0.0.0:2379

# Node 2 Konfiguration (etcd2)
ETCD2_NAME=etcd2
ETCD2_INITIAL_ADVERTISE_PEER_URLS=http://etcd2:2380
ETCD2_LISTEN_PEER_URLS=http://0.0.0.0:2380
ETCD2_ADVERTISE_CLIENT_URLS=http://etcd2:2379
ETCD2_LISTEN_CLIENT_URLS=http://0.0.0.0:2379

# Node 3 Konfiguration (etcd3)
ETCD3_NAME=etcd3
ETCD3_INITIAL_ADVERTISE_PEER_URLS=http://etcd3:2380
ETCD3_LISTEN_PEER_URLS=http://0.0.0.0:2380
ETCD3_ADVERTISE_CLIENT_URLS=http://etcd3:2379
ETCD3_LISTEN_CLIENT_URLS=http://0.0.0.0:2379

# Initial Cluster (alle 3 Nodes)
ETCD_INITIAL_CLUSTER=etcd1=http://etcd1:2380,etcd2=http://etcd2:2380,etcd3=http://etcd3:2380
ETCD_INITIAL_CLUSTER_STATE=new
