# Alertmanager Configuration - Ablage-System OCR
# Copy this file to .env and configure with your credentials

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty Integration
PAGERDUTY_SERVICE_KEY=your_pagerduty_service_key_here

# OpsGenie Integration
OPSGENIE_API_KEY=your_opsgenie_api_key_here

# Email Configuration
ALERT_EMAIL_TO=alerts@yourdomain.com
ALERT_EMAIL_FROM=alertmanager@ablage-system.local
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# Webhook Receiver
WEBHOOK_SECRET=change_this_to_a_secure_random_string
BACKEND_API_URL=http://backend:8000

# Alertmanager External URL (for links in alerts)
ALERTMANAGER_EXTERNAL_URL=http://alertmanager.ablage-system.local
