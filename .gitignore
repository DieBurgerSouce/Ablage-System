# =============================================================================
# GLOBAL ENTERPRISE .GITIGNORE
# Project: Ablage-System
# =============================================================================

# -----------------------------------------------------------------------------
# STRICT ROOT POLICY
# -----------------------------------------------------------------------------
/*
!/.gitignore
!/.dockerignore
!/.editorconfig
!/.pre-commit-config.yaml
!/pyproject.toml
!/package.json
!/package-lock.json
!/requirements.txt
!/requirements-dev.txt
!/requirements-gpu.txt
!/Dockerfile
!/docker-compose*.yml
!/docker-compose*.yaml
!/Makefile
!/README.md
!/CLAUDE.md
!/VERSION
!/LICENSE
!/ARCHITECTURE.md
!/CONTRIBUTING.md
!/SECURITY.md
!/CHANGELOG.md
!/CONVENTIONS.md
!/alembic.ini
!/jest.config.js
!/playwright.config.ts
!/tsconfig.json
!/.releaserc.json
!/.secrets.baseline
!/.yamllint.yml
!/.markdownlint.json

# Whitelist core directories
!/app/
!/frontend/
!/infrastructure/
!/docs/
!/tests/
!/scripts/
!/.github/
!/.vscode/
!/.devcontainer/

# -----------------------------------------------------------------------------
# PYTHON & CORE
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
venv/
.venv/
ENV/
env/

# -----------------------------------------------------------------------------
# JAVASCRIPT & FRONTEND
# -----------------------------------------------------------------------------
node_modules/
/frontend/dist/
/frontend/build/
.next/
.out/
.vercel
.npm
.eslintcache
*.tsbuildinfo

# -----------------------------------------------------------------------------
# SECRETS & ENVIRONMENT
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.pfx
*.crt
secrets/
vault/
*.txt
!/requirements*.txt
!*.md

# -----------------------------------------------------------------------------
# OS & IDE
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
*.swp
*.swo
.project
.settings/
.pydevproject

# -----------------------------------------------------------------------------
# DATA, MODELS & BINARIES
# -----------------------------------------------------------------------------
data/
!data/.gitkeep
models/
!models/.gitkeep
*.pt
*.pth
*.bin
*.pkl
*.h5
*.onnx
*.safetensors
*.zip
*.tar
*.gz
*.7z
*.rar
*.exe
*.dll
*.so
*.dylib
*.log
logs/
/tmp/
/quarantine/
nul
=2.0.0

# -----------------------------------------------------------------------------
# SCANNER & TOOLING ARTIFACTS
# -----------------------------------------------------------------------------
.pytest_cache/
.hypothesis/
.kiro/
.playwright-mcp/
.cache/
test-reports/
htmlcov/
.coverage
.coverage.*
.tox/
.nox/
.ruff_cache/
.mypy_cache/
.pytype/
