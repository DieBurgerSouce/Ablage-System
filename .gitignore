# Alerting secrets (Sprint 0 / G01, Task D)
infrastructure/alerting/slack-webhook.url
infrastructure/alerting/teams-webhook.url
infrastructure/alerting/smtp-password

# Prometheus scrape tokens (mounted into prometheus container)
infrastructure/prometheus/qdrant_metrics_token
infrastructure/prometheus/metrics_scrape_token

# Watchdog runtime logs (Sprint 0 / G05) - State liegt im Docker-Volume
scripts/watchdog/logs/

# Claude-Flow Runtime in beliebigen Subdirectories (Phase B 2026-05-19)
# Im Root-Repo werden `.claude-flow/metrics/*.json` als Audit-Baseline
# committet; in Sub-Workdirs (z.B. frontend/.claude-flow/) ist alles
# nur Runtime-Cruft.
**/.claude-flow/daemon-state.json
**/.claude-flow/daemon-children.json
**/.claude-flow/daemon.pid
**/.claude-flow/.trend-cache.json
**/.claude-flow/data/
**/.claude-flow/logs/
**/.claude-flow/sessions/
**/.claude-flow/tasks/
**/.claude-flow/workflows/
**/.claude-flow/learning/
**/.claude-flow/neural/
# Subdir-Daemon-Instanzen komplett ignorieren (nur das Root .claude-flow/ ist relevant)
/frontend/.claude-flow/

# Python scripts in root
/reset_password.py

# Claude-Flow / swarm runtime churn (override: NOT an audit baseline, pure runtime cruft - 2026-06)
.claude-flow/metrics/
.claude-flow/swarm/
.swarm/state.json
.claude/worktrees/

# DB-Dumps/Backups (lokal, nie committen)
backups/

# A-Z-Loop Rohlogs
.claude/reviews/*/loop-logs/
