infrastructure/vault/config/certs/

# LAN-TLS-Zertifikate (M-14, scripts/generate-lan-tls.sh) - NIEMALS committen!
# Verzeichnis selbst bleibt via .gitkeep im Repo (nginx-ssl-Mount).
infrastructure/nginx/ssl/*
!infrastructure/nginx/ssl/.gitkeep

# Nginx security files (never commit!)
infrastructure/nginx/.htpasswd
infrastructure/nginx/dhparam.pem

# Vault secrets (NEVER commit these!)
infrastructure/vault/.vault*

# Browser Diagnostics - Temporary files (21 MB Dumps mit PII/JWTs - NICHT committen)
browser-diagnostics/
*.png
!frontend/public/*.png
!docs/**/*.png
screenshots/
test-reports/

# Temporary test scripts (keep only the main suite)
test_*.js
!tests/e2e/ultra-browser-diagnostics.js
run-*.bat
run-*.js

# Root-level temporary files
*.md
!README.md
!CLAUDE.md
!ARCHITECTURE.md
!DEPLOYMENT.md
!CONVENTIONS.md
!docs/**/*.md
!.claude/**/*.md
