#!/bin/bash
# Git Pre-Commit Hook - Ablage-System
# Runs code quality checks before allowing commit

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}🔍 Running pre-commit checks...${NC}\n"

# Check if we're in the repo root
if [ ! -f "pyproject.toml" ]; then
    echo -e "${RED}❌ Error: Must be in repository root${NC}"
    exit 1
fi

# Activate virtual environment if it exists
if [ -d "venv" ]; then
    source venv/bin/activate 2>/dev/null || source venv/Scripts/activate 2>/dev/null || true
fi

# Get list of staged Python files
STAGED_PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.py$" || true)

if [ -z "$STAGED_PYTHON_FILES" ]; then
    echo -e "${GREEN}✅ No Python files staged, skipping checks${NC}"
    exit 0
fi

echo -e "${YELLOW}Checking files:${NC}"
echo "$STAGED_PYTHON_FILES" | sed 's/^/  - /'
echo ""

# 1. Ruff Linting
echo -e "${YELLOW}1. Running Ruff linting...${NC}"
if ! ruff check $STAGED_PYTHON_FILES; then
    echo -e "${RED}❌ Ruff linting failed!${NC}"
    echo -e "${YELLOW}💡 Run: ruff check . --fix${NC}"
    exit 1
fi
echo -e "${GREEN}✅ Ruff linting passed${NC}\n"

# 2. Ruff Formatting
echo -e "${YELLOW}2. Checking code formatting...${NC}"
if ! ruff format --check $STAGED_PYTHON_FILES; then
    echo -e "${RED}❌ Code formatting check failed!${NC}"
    echo -e "${YELLOW}💡 Run: ruff format .${NC}"
    exit 1
fi
echo -e "${GREEN}✅ Code formatting passed${NC}\n"

# 3. MyPy Type Checking (only for app/ files)
APP_FILES=$(echo "$STAGED_PYTHON_FILES" | grep "^app/" || true)
if [ -n "$APP_FILES" ]; then
    echo -e "${YELLOW}3. Running MyPy type checking...${NC}"
    if ! mypy $APP_FILES; then
        echo -e "${RED}❌ Type checking failed!${NC}"
        echo -e "${YELLOW}💡 Fix type errors before committing${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ Type checking passed${NC}\n"
else
    echo -e "${YELLOW}3. Skipping MyPy (no app/ files)${NC}\n"
fi

# 4. Check for debugging statements
echo -e "${YELLOW}4. Checking for debugging code...${NC}"
FORBIDDEN_PATTERNS=(
    "import pdb"
    "pdb.set_trace()"
    "breakpoint()"
    "print("
    "console.log("
)

for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    if echo "$STAGED_PYTHON_FILES" | xargs grep -n "$pattern" 2>/dev/null; then
        echo -e "${RED}❌ Found debugging code: $pattern${NC}"
        echo -e "${YELLOW}💡 Remove debugging statements before committing${NC}"
        exit 1
    fi
done
echo -e "${GREEN}✅ No debugging code found${NC}\n"

# 5. Check for secrets
echo -e "${YELLOW}5. Checking for potential secrets...${NC}"
SECRET_PATTERNS=(
    "password\s*=\s*['\"][^'\"]+['\"]"
    "api_key\s*=\s*['\"][^'\"]+['\"]"
    "secret\s*=\s*['\"][^'\"]+['\"]"
    "token\s*=\s*['\"][^'\"]+['\"]"
)

for pattern in "${SECRET_PATTERNS[@]}"; do
    if echo "$STAGED_PYTHON_FILES" | xargs grep -iP "$pattern" 2>/dev/null; then
        echo -e "${RED}❌ Potential secret found!${NC}"
        echo -e "${YELLOW}💡 Use environment variables for secrets${NC}"
        exit 1
    fi
done
echo -e "${GREEN}✅ No secrets found${NC}\n"

# 6. Check file size
echo -e "${YELLOW}6. Checking file sizes...${NC}"
MAX_SIZE=1048576  # 1MB in bytes

for file in $STAGED_PYTHON_FILES; do
    if [ -f "$file" ]; then
        size=$(wc -c < "$file")
        if [ "$size" -gt "$MAX_SIZE" ]; then
            echo -e "${RED}❌ File too large: $file ($(($size / 1024))KB)${NC}"
            echo -e "${YELLOW}💡 Consider splitting large files${NC}"
            exit 1
        fi
    fi
done
echo -e "${GREEN}✅ File sizes OK${NC}\n"

# All checks passed!
echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
echo -e "${GREEN}🚀 Ready to commit${NC}"

exit 0
