# Ablage-System Production Environment
# =====================================
# WICHTIG: Diese Datei enthaelt KEINE Secrets!
# Alle sensiblen Daten werden ueber Vault verwaltet.
#
# Workflow:
# 1. Kopieren: cp .env.production.example .env
# 2. Vault initialisieren: cd infrastructure/vault && ./setup-vault.sh
# 3. VAULT_TOKEN aus setup-vault.sh Ausgabe setzen
# 4. VAULT_ENABLED=true setzen
# 5. docker-compose up -d

# ============================================
# VAULT KONFIGURATION (ERFORDERLICH)
# ============================================
VAULT_ENABLED=true
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=                           # Aus Vault-Initialisierung
VAULT_SECRET_PATH=ablage-system
VAULT_MOUNT_POINT=secret

# ============================================
# GPU KONFIGURATION
# ============================================
CUDA_VISIBLE_DEVICES=0

# ============================================
# ANWENDUNGSEINSTELLUNGEN (nicht sensitiv)
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=INFO
DEBUG=false

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_DOCUMENTS_PER_HOUR=10
DEFAULT_USER_DAILY_QUOTA=100

# Rate Limit Tiers
RATE_LIMIT_FREE_HOURLY=10
RATE_LIMIT_FREE_DAILY=50
RATE_LIMIT_PREMIUM_HOURLY=100
RATE_LIMIT_PREMIUM_DAILY=1000
RATE_LIMIT_ADMIN_HOURLY=10000

# Rate Limit Windows (Sekunden)
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_REGISTER_ATTEMPTS=3
RATE_LIMIT_REGISTER_WINDOW=3600

# Rate Limit Whitelist (komma-separierte IPs)
# RATE_LIMIT_WHITELIST=127.0.0.1,::1

# ============================================
# JWT KONFIGURATION (Tokens werden aus Vault geladen)
# ============================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# ALERTING KONFIGURATION
# ============================================
# SMTP und Teams-Webhooks werden aus Vault geladen
# Hier nur nicht-sensitive Defaults
SMTP_PORT=587
SMTP_FROM=alertmanager@ablage-system.local
EMAIL_RECIPIENTS=ops-team@internal.local

# ============================================
# GRAFANA (nicht-sensitiv)
# ============================================
GRAFANA_USER=admin
# GRAFANA_PASSWORD wird ueber Vault geladen

# ============================================
# FALLBACK-WERTE (nur fuer lokale Entwicklung)
# Diese werden ignoriert wenn VAULT_ENABLED=true
# ============================================
# WARNUNG: Diese Werte NUR fuer Entwicklung nutzen!
# In Production muessen alle Secrets in Vault sein.
#
# DB_PASSWORD=                         # Nicht setzen in Production!
# MINIO_ROOT_USER=                     # Nicht setzen in Production!
# MINIO_ROOT_PASSWORD=                 # Nicht setzen in Production!
# SECRET_KEY=                          # Nicht setzen in Production!
# TEAMS_WEBHOOK_URL=                   # In Vault speichern!

# ============================================
# DOCKER SERVICES (interne Verbindungen)
# ============================================
# Diese URLs werden automatisch aus docker-compose.yml verwendet
# DATABASE_URL=postgresql+asyncpg://...@postgres:5432/ablage_system
# REDIS_URL=redis://redis:6379/0
# MINIO_ENDPOINT=minio:9000

# ============================================
# SICHERHEITSHINWEISE
# ============================================
# 1. Diese Datei darf in Git eingecheckt werden
# 2. Die echte .env Datei NIEMALS committen
# 3. Vault Token sicher aufbewahren (nicht in .env!)
# 4. Unseal Keys offline sichern
# 5. Regelmaessig Tokens rotieren
