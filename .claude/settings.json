            "type": "command",
            "command": "python C:\\Users\\benfi\\Ablage_System\\.claude\\hooks\\post_plan_mode.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python C:\\Users\\benfi\\Ablage_System\\.claude\\hooks\\auto_orchestration_hook.py"
